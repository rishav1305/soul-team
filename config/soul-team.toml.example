# Soul Team v2 — Example Configuration
# Copy to ~/.soul-team/config.toml and customize with your real values.
#
# Config resolution order (first found wins):
#   1. $SOUL_TEAM_CONFIG env var
#   2. ~/.soul-team/config.toml          (user config — primary)
#   3. ~/.claude/config/soul-team.toml   (legacy path — backward compat)
#   4. ./config/soul-team.toml.example   (repo default — last resort)

[team]
name = "my-team"
description = "AI agent team"
boot_prompt = "Run your daily routine then enter proactive mode when idle."
stagger_seconds = 10

[policies]
permission_mode = "bypassPermissions"
agent_memory = true
communication = "full"
guardian = true
courier = true
idle_shutdown = false

# ─── Local agents ───

[[agents]]
name = "developer-1"
model = "sonnet"
machine = "local"
cgroup = true
template = "developer"

[[agents]]
name = "researcher-1"
model = "sonnet"
machine = "local"
cgroup = true
template = "researcher"

[[agents]]
name = "assistant-1"
model = "haiku"
machine = "local"
cgroup = true
template = "assistant"

# ─── Remote agents (uncomment and customize) ───

# [[agents]]
# name = "developer-2"
# model = "sonnet"
# machine = "worker-1"
# ssh = "user@remote-host"
# cgroup = false
# template = "developer"

# ─── tmux layout ───

[layout]
columns = 2  # CEO + 1 agent column
rows = 3

[[layout.grid]]
col = 1
agents = ["developer-1", "researcher-1", "assistant-1"]
