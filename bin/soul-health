#!/bin/bash
# soul-health.sh — At-a-glance health dashboard for soul-team infrastructure
#
# Reports:
#   - Service statuses (guardian, courier, router)
#   - Event queue sizes
#   - Courier queue depths per agent
#   - Agent memory sizes
#   - Guardian DB size
#   - Last guardian restart per agent
#   - Stuck message detection
#
# Usage:
#   soul-health           # Full dashboard
#   soul-health --json    # Machine-readable JSON output

set -euo pipefail

# ── Colors ───────────────────────────────────────────────────────────────────
GREEN='\033[0;32m'
RED='\033[0;31m'
YELLOW='\033[1;33m'
CYAN='\033[0;36m'
BOLD='\033[1m'
DIM='\033[2m'
NC='\033[0m' # No Color

JSON_MODE=false
[[ "${1:-}" == "--json" ]] && JSON_MODE=true

# ── Helpers ──────────────────────────────────────────────────────────────────
ok()   { echo -e "  ${GREEN}[OK]${NC}   $1"; }
fail() { echo -e "  ${RED}[DOWN]${NC} $1"; }
warn() { echo -e "  ${YELLOW}[WARN]${NC} $1"; }
info() { echo -e "  ${DIM}$1${NC}"; }

service_status() {
    local svc="$1"
    if systemctl --user is-active --quiet "$svc" 2>/dev/null; then
        echo "running"
    elif pgrep -f "$svc" >/dev/null 2>&1; then
        echo "running-direct"
    else
        echo "stopped"
    fi
}

human_size() {
    local bytes="$1"
    if (( bytes >= 1073741824 )); then
        echo "$(( bytes / 1073741824 ))G"
    elif (( bytes >= 1048576 )); then
        echo "$(( bytes / 1048576 ))M"
    elif (( bytes >= 1024 )); then
        echo "$(( bytes / 1024 ))K"
    else
        echo "${bytes}B"
    fi
}

TEAM_DIR="$HOME/.clawteam/teams/soul-team"
GUARDIAN_DB="$HOME/.soul/guardian.db"
# GUARDIAN_LOG is available for future log-tail features
# shellcheck disable=SC2034
GUARDIAN_LOG="$HOME/.soul/guardian.log"
AGENTS=(happy xavier hawkeye pepper fury loki shuri stark banner)

# ── JSON mode ────────────────────────────────────────────────────────────────
if $JSON_MODE; then
    # Build JSON output
    guardian_status=$(service_status "soul-guardian")
    courier_status=$(service_status "soul-courier")
    router_status=$(service_status "soul-router")

    # Queue sizes
    broadcast_count=$(find "$TEAM_DIR/broadcast" -name "*.json" 2>/dev/null | wc -l)
    discussion_count=$(find "$TEAM_DIR/discussions" -maxdepth 1 -name "*.json" 2>/dev/null | wc -l)

    # Guardian DB size
    db_size=0
    [ -f "$GUARDIAN_DB" ] && db_size=$(stat -c%s "$GUARDIAN_DB" 2>/dev/null || echo 0)

    # Agent queues
    agent_queues="{"
    first=true
    for agent in "${AGENTS[@]}"; do
        queue_dir="$TEAM_DIR/inboxes/${agent}_${agent}"
        count=$(find "$queue_dir" -maxdepth 1 -name "*.json" 2>/dev/null | wc -l)
        $first || agent_queues+=","
        agent_queues+="\"$agent\":$count"
        first=false
    done
    agent_queues+="}"

    # Agent memory sizes
    agent_memory_sizes="{"
    first_mem=true
    for agent in "${AGENTS[@]}"; do
        mem_dir="$HOME/.claude/agent-memory/${agent}"
        if [ -d "$mem_dir" ]; then
            size_human=$(du -sh "$mem_dir" 2>/dev/null | cut -f1)
        else
            size_human="0"
        fi
        $first_mem || agent_memory_sizes+=","
        agent_memory_sizes+="\"$agent\":\"$size_human\""
        first_mem=false
    done
    agent_memory_sizes+="}"

    # Stuck agents (messages older than 10 min)
    stuck_agents="["
    first_stuck=true
    for agent in "${AGENTS[@]}"; do
        inbox_dir="$TEAM_DIR/inboxes/${agent}_${agent}"
        old_count=$(find "$inbox_dir" -maxdepth 1 -name "*.json" -mmin +10 2>/dev/null | wc -l)
        if [ "$old_count" -gt 0 ]; then
            $first_stuck || stuck_agents+=","
            stuck_agents+="{\"agent\":\"$agent\",\"stale_messages\":$old_count}"
            first_stuck=false
        fi
    done
    stuck_agents+="]"

    # Recent restarts from guardian DB
    recent_restarts="[]"
    if [ -f "$GUARDIAN_DB" ] && command -v sqlite3 >/dev/null 2>&1; then
        recent_restarts=$(sqlite3 "$GUARDIAN_DB" \
            "SELECT '[' || GROUP_CONCAT(json_object('agent', a, 'last_restart', lr, 'total', cnt)) || ']' FROM (SELECT agent AS a, MAX(timestamp) AS lr, COUNT(*) AS cnt FROM self_heal_events WHERE event_type='restart' GROUP BY agent ORDER BY lr DESC LIMIT 10);" 2>/dev/null || echo "[]")
        [ -z "$recent_restarts" ] && recent_restarts="[]"
    fi

    # Today's spend from guardian DB
    today_spend="0.00"
    if [ -f "$GUARDIAN_DB" ] && command -v sqlite3 >/dev/null 2>&1; then
        today=$(date +%Y-%m-%d)
        today_spend=$(sqlite3 "$GUARDIAN_DB" \
            "SELECT COALESCE(printf('%.2f', SUM(total_cost)), '0.00') FROM daily_spend WHERE date='$today'" 2>/dev/null || echo "0.00")
    fi

    # System resources
    temp_raw=$(cat /sys/class/thermal/thermal_zone0/temp 2>/dev/null || echo 0)
    temp_c=$((temp_raw / 1000))
    mem_avail_kb=$(grep MemAvailable /proc/meminfo 2>/dev/null | awk '{print $2}')
    mem_total_kb=$(grep MemTotal /proc/meminfo 2>/dev/null | awk '{print $2}')
    mem_used_mb=0
    mem_total_mb=0
    mem_pct=0
    if [ -n "$mem_avail_kb" ] && [ -n "$mem_total_kb" ] && [ "$mem_total_kb" -gt 0 ]; then
        mem_used_mb=$(( (mem_total_kb - mem_avail_kb) / 1024 ))
        mem_total_mb=$((mem_total_kb / 1024))
        mem_pct=$(( (mem_total_kb - mem_avail_kb) * 100 / mem_total_kb ))
    fi
    load_avg=$(awk '{print $1}' /proc/loadavg 2>/dev/null || echo "0")

    cat <<EOF
{
  "timestamp": "$(date -u +%Y-%m-%dT%H:%M:%SZ)",
  "services": {
    "guardian": "$guardian_status",
    "courier": "$courier_status",
    "router": "$router_status"
  },
  "queues": {
    "broadcast": $broadcast_count,
    "discussions": $discussion_count
  },
  "agent_inbox_depths": $agent_queues,
  "guardian_db_bytes": $db_size,
  "agent_memory_sizes": $agent_memory_sizes,
  "stuck_agents": $stuck_agents,
  "recent_restarts": $recent_restarts,
  "today_spend": $today_spend,
  "system_resources": {
    "cpu_temp_c": $temp_c,
    "memory_used_mb": $mem_used_mb,
    "memory_total_mb": $mem_total_mb,
    "memory_pct": $mem_pct,
    "load_avg_1m": $load_avg
  }
}
EOF
    exit 0
fi

# ── 0. tmux session check ───────────────────────────────────────────────────
if tmux has-session -t soul-team 2>/dev/null; then
    TMUX_STATUS="RUNNING"
    TMUX_PANE_COUNT=$(tmux list-panes -t soul-team 2>/dev/null | wc -l)
else
    TMUX_STATUS="NOT RUNNING"
    TMUX_PANE_COUNT=0
fi

# ── Header ───────────────────────────────────────────────────────────────────
echo ""
echo -e "${BOLD}${CYAN}  SOUL-TEAM HEALTH DASHBOARD${NC}"
echo -e "  ${DIM}$(date '+%Y-%m-%d %H:%M:%S %Z')${NC}"
echo -e "  ${DIM}────────────────────────────────────────${NC}"
echo ""

# ── tmux session ────────────────────────────────────────────────────────────
echo -e "${BOLD}  tmux Session${NC}"
if [[ "$TMUX_STATUS" == "RUNNING" ]]; then
    ok "tmux session: RUNNING"
    echo -e "  panes: ${BOLD}${TMUX_PANE_COUNT}${NC}"
else
    fail "tmux session: NOT RUNNING"
fi
echo ""

# ── 1. Service Status ────────────────────────────────────────────────────────
echo -e "${BOLD}  Services${NC}"

for svc in soul-guardian soul-courier soul-router; do
    status=$(service_status "$svc")
    if [[ "$status" == "running" ]]; then
        pid=$(systemctl --user show "$svc" --property=MainPID --value 2>/dev/null || echo "?")
        ok "$svc (pid: $pid)"
    elif [[ "$status" == "running-direct" ]]; then
        pid=$(pgrep -f "$svc" | head -1)
        ok "$svc (direct, pid: $pid)"
    else
        fail "$svc"
    fi
done
echo ""

# ── 2. Event Queue Sizes ────────────────────────────────────────────────────
echo -e "${BOLD}  Event Queues${NC}"

broadcast_count=$(find "$TEAM_DIR/broadcast" -name "*.json" 2>/dev/null | wc -l)
discussion_pending=$(find "$TEAM_DIR/discussions" -maxdepth 1 -name "*.json" 2>/dev/null | wc -l)

# Count active discussion threads
active_threads=0
for d in "$TEAM_DIR/discussions"/*/; do
    [ -d "$d" ] || continue
    state_file="${d}state.json"
    if [ -f "$state_file" ]; then
        status=$(python3 -c "import json; print(json.load(open('$state_file')).get('status',''))" 2>/dev/null)
        [ "$status" = "active" ] && active_threads=$((active_threads + 1))
    fi
done

echo -e "  Broadcast queue:    ${BOLD}${broadcast_count}${NC} pending"
echo -e "  Discussion requests: ${BOLD}${discussion_pending}${NC} pending"
echo -e "  Active threads:     ${BOLD}${active_threads}${NC}"
echo ""

# ── 3. Courier Queue Depths ─────────────────────────────────────────────────
echo -e "${BOLD}  Agent Inbox Depths${NC}"
printf "  ${DIM}%-14s %6s %6s${NC}\n" "AGENT" "INBOX" "ARCHIVE"
printf "  ${DIM}%-14s %6s %6s${NC}\n" "──────────" "─────" "───────"

total_inbox=0
stuck_agents=()
for agent in "${AGENTS[@]}"; do
    inbox_dir="$TEAM_DIR/inboxes/${agent}_${agent}"
    archive_dir="$inbox_dir/archive"
    inbox_count=$(find "$inbox_dir" -maxdepth 1 -name "*.json" 2>/dev/null | wc -l)
    archive_count=$(find "$archive_dir" -name "*.json" 2>/dev/null | wc -l)
    total_inbox=$((total_inbox + inbox_count))

    # Color code: green if 0, yellow if 1-5, red if 6+
    if (( inbox_count == 0 )); then
        color="${GREEN}"
    elif (( inbox_count <= 5 )); then
        color="${YELLOW}"
    else
        color="${RED}"
        stuck_agents+=("$agent")
    fi
    printf "  %-14s ${color}%6d${NC} %6d\n" "$agent" "$inbox_count" "$archive_count"
done
echo -e "  ${DIM}Total undelivered: ${BOLD}${total_inbox}${NC}"
echo ""

# ── 4. Agent Memory Sizes ───────────────────────────────────────────────────
echo -e "${BOLD}  Agent Memory Sizes${NC}"
printf "  ${DIM}%-14s %10s${NC}\n" "AGENT" "SIZE"
printf "  ${DIM}%-14s %10s${NC}\n" "──────────" "────────"

for agent in "${AGENTS[@]}"; do
    mem_dir="$HOME/.claude/agent-memory/${agent}"
    if [ -d "$mem_dir" ]; then
        size_bytes=$(du -sb "$mem_dir" 2>/dev/null | cut -f1)
        size_human=$(human_size "$size_bytes")
        printf "  %-14s %10s\n" "$agent" "$size_human"
    else
        printf "  %-14s ${DIM}%10s${NC}\n" "$agent" "(none)"
    fi
done
echo ""

# ── 5. Guardian DB ───────────────────────────────────────────────────────────
echo -e "${BOLD}  Guardian Database${NC}"
if [ -f "$GUARDIAN_DB" ]; then
    db_size=$(stat -c%s "$GUARDIAN_DB" 2>/dev/null || echo 0)
    db_human=$(human_size "$db_size")
    ok "guardian.db: $db_human"

    # Last restart events per agent
    if command -v sqlite3 >/dev/null 2>&1; then
        echo -e "  ${DIM}Recent restarts:${NC}"
        sqlite3 "$GUARDIAN_DB" \
            "SELECT agent, MAX(timestamp), COUNT(*) FROM self_heal_events WHERE event_type='restart' GROUP BY agent ORDER BY MAX(timestamp) DESC LIMIT 10" 2>/dev/null | \
        while IFS='|' read -r agent ts count; do
            printf "    %-14s last: %s  (total: %s)\n" "$agent" "$ts" "$count"
        done
        # Today's spend
        today=$(date +%Y-%m-%d)
        total_spend=$(sqlite3 "$GUARDIAN_DB" \
            "SELECT COALESCE(printf('%.2f', SUM(total_cost)), '0.00') FROM daily_spend WHERE date='$today'" 2>/dev/null)
        echo -e "  ${DIM}Today's spend: ${BOLD}\$${total_spend}${NC}"
    fi
else
    warn "guardian.db not found at $GUARDIAN_DB"
fi
echo ""

# ── 6. Stuck Messages ───────────────────────────────────────────────────────
echo -e "${BOLD}  Stuck Message Detection${NC}"
stuck_found=false
for agent in "${AGENTS[@]}"; do
    inbox_dir="$TEAM_DIR/inboxes/${agent}_${agent}"
    # Find messages older than 10 minutes
    old_msgs=$(find "$inbox_dir" -maxdepth 1 -name "*.json" -mmin +10 2>/dev/null)
    if [ -n "$old_msgs" ]; then
        count=$(echo "$old_msgs" | wc -l)
        oldest=$(echo "$old_msgs" | head -1)
        oldest_age=$(( ($(date +%s) - $(stat -c%Y "$oldest" 2>/dev/null || date +%s)) / 60 ))
        warn "$agent: $count message(s) older than 10min (oldest: ${oldest_age}min)"
        stuck_found=true
    fi
done
if ! $stuck_found; then
    ok "No stuck messages detected"
fi
echo ""

# ── 7. System Resources ─────────────────────────────────────────────────────
echo -e "${BOLD}  System Resources${NC}"

# CPU temp
temp_raw=$(cat /sys/class/thermal/thermal_zone0/temp 2>/dev/null || echo 0)
temp_c=$((temp_raw / 1000))
if (( temp_c >= 80 )); then
    echo -e "  CPU temp: ${RED}${BOLD}${temp_c}C${NC} (CRITICAL)"
elif (( temp_c >= 70 )); then
    echo -e "  CPU temp: ${YELLOW}${temp_c}C${NC}"
else
    echo -e "  CPU temp: ${GREEN}${temp_c}C${NC}"
fi

# Memory
mem_avail_kb=$(grep MemAvailable /proc/meminfo 2>/dev/null | awk '{print $2}')
mem_total_kb=$(grep MemTotal /proc/meminfo 2>/dev/null | awk '{print $2}')
if [ -n "$mem_avail_kb" ] && [ -n "$mem_total_kb" ]; then
    mem_used_mb=$(( (mem_total_kb - mem_avail_kb) / 1024 ))
    mem_total_mb=$((mem_total_kb / 1024))
    mem_pct=$(( (mem_total_kb - mem_avail_kb) * 100 / mem_total_kb ))
    if (( mem_pct >= 90 )); then
        echo -e "  Memory:   ${RED}${BOLD}${mem_used_mb}M / ${mem_total_mb}M (${mem_pct}%)${NC}"
    elif (( mem_pct >= 75 )); then
        echo -e "  Memory:   ${YELLOW}${mem_used_mb}M / ${mem_total_mb}M (${mem_pct}%)${NC}"
    else
        echo -e "  Memory:   ${GREEN}${mem_used_mb}M / ${mem_total_mb}M (${mem_pct}%)${NC}"
    fi
fi

# Load average
load=$(awk '{print $1, $2, $3}' /proc/loadavg 2>/dev/null)
echo -e "  Load avg: $load"
echo ""

# ── Summary ──────────────────────────────────────────────────────────────────
echo -e "${DIM}  ────────────────────────────────────────${NC}"
svc_count=0
for svc in soul-guardian soul-courier soul-router; do
    status=$(service_status "$svc")
    [[ "$status" == running* ]] && svc_count=$((svc_count + 1))
done

if (( svc_count == 3 )); then
    echo -e "  ${GREEN}${BOLD}ALL SERVICES HEALTHY${NC} ($svc_count/3 running, ${total_inbox} queued)"
elif (( svc_count >= 2 )); then
    echo -e "  ${YELLOW}${BOLD}DEGRADED${NC} ($svc_count/3 running, ${total_inbox} queued)"
else
    echo -e "  ${RED}${BOLD}CRITICAL${NC} ($svc_count/3 running, ${total_inbox} queued)"
fi

if [ ${#stuck_agents[@]} -gt 0 ]; then
    echo -e "  ${RED}Stuck agents: ${stuck_agents[*]}${NC}"
fi
echo ""
