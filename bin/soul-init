#!/usr/bin/env python3
"""
soul-init — Interactive setup wizard for soul-team.

Creates a fully configured agent team from user input or quick-start defaults.
Generates TOML config, agent .md files, team protocol, and systemd services.

Usage:
    soul-init                  # Interactive wizard
    soul-init --quick          # 3-agent team with defaults (dev, researcher, assistant)
    soul-init --quick -n 5     # 5-agent team with template rotation
    soul-init --config FILE    # Re-run from existing TOML (edit mode)

Stdlib only — no external dependencies.
"""

from __future__ import annotations

import argparse
import os
import re
import shutil
import signal
import subprocess
import sys
import textwrap
from dataclasses import dataclass, field
from pathlib import Path
from typing import Optional

# ── ANSI colors (same palette as setup.sh) ───────────────────────────────────

BOLD = "\033[1m"
DIM = "\033[2m"
GREEN = "\033[0;32m"
YELLOW = "\033[1;33m"
RED = "\033[0;31m"
CYAN = "\033[0;36m"
MAGENTA = "\033[0;35m"
NC = "\033[0m"

# ── Paths ────────────────────────────────────────────────────────────────────

SCRIPT_DIR = Path(__file__).resolve().parent
REPO_ROOT = SCRIPT_DIR.parent
TEMPLATES_DIR = REPO_ROOT / "agents" / "templates"
PROTOCOL_SRC = REPO_ROOT / "protocols" / "team-protocol-v2.md"
SYSTEMD_SRC = REPO_ROOT / "systemd"

HOME = Path.home()
CLAUDE_CONFIG_DIR = HOME / ".claude" / "config"
CLAUDE_AGENTS_DIR = HOME / ".claude" / "agents"
CLAUDE_LOGS_DIR = HOME / ".claude" / "logs"


# ── Data models ──────────────────────────────────────────────────────────────

AVAILABLE_TEMPLATES = ["developer", "researcher", "assistant", "strategist", "writer", "analyst"]

TEMPLATE_DESCRIPTIONS = {
    "developer": "Writes code, runs tests, manages git, plans sprints",
    "researcher": "Market research, competitive analysis, strategic briefs",
    "assistant": "Task management, scheduling, daily briefings, coordination",
    "strategist": "Market analysis, competitive intel, GTM planning",
    "writer": "Content creation, copywriting, social media, documentation",
    "analyst": "Data analysis, visualization, ML pipelines, statistics",
}

QUICK_START_TEMPLATES = ["developer", "researcher", "assistant"]

MODEL_OPTIONS = ["opus", "sonnet", "haiku"]


@dataclass
class Machine:
    """A remote machine for distributed deployment."""
    name: str
    ssh_target: str  # user@host
    verified: bool = False


@dataclass
class Agent:
    """An agent definition."""
    name: str
    role: str
    model: str = "sonnet"
    machine: str = "local"  # "local" or machine name
    template: Optional[str] = None  # template name if from template
    cgroup: bool = True


@dataclass
class TeamConfig:
    """Full team configuration."""
    team_name: str = "my-team"
    deployment_mode: str = "single"  # "single" or "distributed"
    boot_prompt: str = "Run your daily routine then enter proactive mode when idle."
    stagger_seconds: int = 10
    enable_guardian: bool = True
    enable_courier: bool = True
    enable_idle_shutdown: bool = False
    idle_timeout_minutes: int = 15
    permission_mode: str = "bypassPermissions"
    agent_memory: bool = True
    communication_protocol: str = "full"
    agents: list[Agent] = field(default_factory=list)
    machines: list[Machine] = field(default_factory=list)


# ── UI helpers ───────────────────────────────────────────────────────────────

def banner() -> None:
    """Print the welcome banner."""
    print()
    print(f"{BOLD}{'=' * 60}{NC}")
    print(f"{BOLD}  soul-team init{NC}")
    print(f"{DIM}  Interactive setup wizard for your AI agent team{NC}")
    print(f"{BOLD}{'=' * 60}{NC}")
    print()


def section(title: str) -> None:
    """Print a section header."""
    print()
    print(f"{CYAN}── {title} {'─' * max(1, 50 - len(title))}──{NC}")
    print()


def ok(msg: str) -> None:
    print(f"{GREEN}  [ok] {msg}{NC}")


def warn(msg: str) -> None:
    print(f"{YELLOW}  [!!] {msg}{NC}")


def fail(msg: str) -> None:
    print(f"{RED}  [FAIL] {msg}{NC}")


def info(msg: str) -> None:
    print(f"  {BOLD}{msg}{NC}")


def prompt_str(question: str, default: str = "", allow_empty: bool = False) -> str:
    """Prompt for a string value with optional default."""
    if default:
        display = f"  {BOLD}?{NC} {question} [{default}]: "
    else:
        display = f"  {BOLD}?{NC} {question}: "

    while True:
        answer = input(display).strip()
        if not answer and default:
            return default
        if answer or allow_empty:
            return answer
        print(f"    {RED}Please enter a value.{NC}")


def prompt_int(question: str, default: int, min_val: int = 1, max_val: int = 99) -> int:
    """Prompt for an integer value with bounds."""
    while True:
        raw = prompt_str(question, str(default))
        try:
            val = int(raw)
            if min_val <= val <= max_val:
                return val
            print(f"    {RED}Please enter a number between {min_val} and {max_val}.{NC}")
        except ValueError:
            print(f"    {RED}Please enter a valid number.{NC}")


def prompt_choice(question: str, options: list[str], default: int = 0) -> int:
    """Arrow-key selection would be ideal but we keep it simple with numbers."""
    print(f"  {BOLD}?{NC} {question}")
    for i, opt in enumerate(options):
        marker = f"{GREEN}>{NC}" if i == default else " "
        print(f"    {marker} {i + 1}. {opt}")

    while True:
        raw = input(f"    Choice [{default + 1}]: ").strip()
        if not raw:
            return default
        try:
            idx = int(raw) - 1
            if 0 <= idx < len(options):
                return idx
            print(f"    {RED}Please enter 1-{len(options)}.{NC}")
        except ValueError:
            print(f"    {RED}Please enter a number.{NC}")


def prompt_yn(question: str, default: bool = True) -> bool:
    """Yes/No prompt."""
    hint = "Y/n" if default else "y/N"
    raw = input(f"  {BOLD}?{NC} {question} [{hint}]: ").strip().lower()
    if not raw:
        return default
    return raw in ("y", "yes")


def prompt_multi_select(question: str, options: list[str], descriptions: dict[str, str]) -> list[str]:
    """Let user pick multiple items from a list (comma-separated numbers)."""
    print(f"  {BOLD}?{NC} {question}")
    for i, opt in enumerate(options):
        desc = descriptions.get(opt, "")
        print(f"    {i + 1}. {BOLD}{opt}{NC} — {DIM}{desc}{NC}")

    while True:
        raw = input(f"    Select (comma-separated, e.g. 1,3,5): ").strip()
        if not raw:
            return []
        try:
            indices = [int(x.strip()) - 1 for x in raw.split(",")]
            selected = []
            for idx in indices:
                if 0 <= idx < len(options):
                    selected.append(options[idx])
                else:
                    raise ValueError
            if selected:
                return selected
        except ValueError:
            pass
        print(f"    {RED}Please enter valid numbers separated by commas.{NC}")


# ── SSH validation ───────────────────────────────────────────────────────────

def test_ssh(target: str) -> bool:
    """Test SSH connectivity to a remote machine."""
    try:
        result = subprocess.run(
            ["ssh", "-o", "ConnectTimeout=5", "-o", "BatchMode=yes", target, "echo ok"],
            capture_output=True,
            text=True,
            timeout=10,
        )
        return result.returncode == 0 and "ok" in result.stdout
    except (subprocess.TimeoutExpired, FileNotFoundError):
        return False


# ── Template loading ─────────────────────────────────────────────────────────

def load_template(template_name: str) -> str:
    """Load a template file and return its content."""
    path = TEMPLATES_DIR / f"{template_name}.md"
    if not path.exists():
        return ""
    return path.read_text()


def render_template(template_content: str, agent_name: str) -> str:
    """Replace {{AGENT_NAME}} placeholders in template."""
    return template_content.replace("{{AGENT_NAME}}", agent_name.capitalize())


# ── Wizard steps ─────────────────────────────────────────────────────────────

def step_deployment_mode(config: TeamConfig) -> None:
    """Step 1: Single or distributed deployment."""
    section("Step 1: Deployment Mode")
    idx = prompt_choice(
        "How will you run your agents?",
        [
            "Single machine (all agents run locally)",
            "Distributed (agents across multiple machines via SSH)",
        ],
        default=0,
    )
    config.deployment_mode = "single" if idx == 0 else "distributed"


def step_machines(config: TeamConfig) -> None:
    """Step 3 (distributed only): Configure remote machines."""
    if config.deployment_mode != "distributed":
        return

    section("Step 3: Remote Machines")
    info("Define your remote machines. Agents will be assigned to them next.")
    print()

    while True:
        name = prompt_str("Remote machine name (e.g. worker-1)")
        ssh_target = prompt_str(f"SSH target for '{name}' (user@host)")

        verified = False
        if prompt_yn("Test SSH connection?"):
            print(f"    Testing {ssh_target}...", end=" ", flush=True)
            if test_ssh(ssh_target):
                print(f"{GREEN}Connected{NC}")
                verified = True
            else:
                print(f"{RED}Failed{NC}")
                warn(f"Could not connect to {ssh_target}. You can fix this later in the TOML config.")

        config.machines.append(Machine(name=name, ssh_target=ssh_target, verified=verified))

        if not prompt_yn("Add another remote machine?", default=False):
            break


def step_agents(config: TeamConfig) -> None:
    """Step 2: Define agents."""
    section("Step 2: Agents")

    num_agents = prompt_int("How many agents?", default=3, min_val=1, max_val=20)

    idx = prompt_choice(
        "How do you want to define your agents?",
        [
            f"Quick start (pick from {len(AVAILABLE_TEMPLATES)} templates)",
            "Custom (define each agent from scratch)",
            "Mix (templates + custom)",
        ],
        default=0,
    )

    if idx == 0:
        # Template-based
        _agents_from_templates(config, num_agents)
    elif idx == 1:
        # Fully custom
        _agents_custom(config, num_agents)
    else:
        # Mix
        _agents_mixed(config, num_agents)


def _agents_from_templates(config: TeamConfig, num_agents: int) -> None:
    """Pick N agents from templates."""
    print()
    info("Available templates:")
    selected = prompt_multi_select(
        f"Pick {num_agents} templates (or fewer, and we'll duplicate as needed):",
        AVAILABLE_TEMPLATES,
        TEMPLATE_DESCRIPTIONS,
    )

    if not selected:
        selected = QUICK_START_TEMPLATES[:num_agents]
        warn(f"No selection — using defaults: {', '.join(selected)}")

    # Pad with rotation if user picked fewer than num_agents
    agents_list = []
    for i in range(num_agents):
        template = selected[i % len(selected)]
        default_name = template if i < len(selected) else f"{template}{i + 1}"

        # For duplicates, auto-number
        existing_names = [a.name for a in agents_list]
        if default_name in existing_names:
            suffix = 2
            while f"{template}{suffix}" in existing_names:
                suffix += 1
            default_name = f"{template}{suffix}"

        name = prompt_str(f"Agent {i + 1} name (template: {template})", default=default_name)
        model = _prompt_model(name)
        machine = _prompt_machine(config, name)

        agents_list.append(Agent(
            name=name,
            role=TEMPLATE_DESCRIPTIONS.get(template, f"{template} agent"),
            model=model,
            machine=machine,
            template=template,
        ))

    config.agents = agents_list


def _agents_custom(config: TeamConfig, num_agents: int) -> None:
    """Define each agent from scratch."""
    print()
    for i in range(num_agents):
        print(f"  {DIM}--- Agent {i + 1} of {num_agents} ---{NC}")
        name = prompt_str(f"Agent {i + 1} name")
        role = prompt_str(f"Agent {i + 1} role (one-line description)")
        model = _prompt_model(name)
        machine = _prompt_machine(config, name)

        # Optionally base on a template
        use_template = prompt_yn(f"Base {name}'s persona on a template?", default=True)
        template = None
        if use_template:
            tidx = prompt_choice(
                "Which template?",
                [f"{t} — {TEMPLATE_DESCRIPTIONS[t]}" for t in AVAILABLE_TEMPLATES],
                default=0,
            )
            template = AVAILABLE_TEMPLATES[tidx]

        config.agents.append(Agent(
            name=name,
            role=role,
            model=model,
            machine=machine,
            template=template,
        ))
        print()


def _agents_mixed(config: TeamConfig, num_agents: int) -> None:
    """Mix of templates and custom agents."""
    print()
    info("First, pick templates for some agents. Then define the rest custom.")
    selected_templates = prompt_multi_select(
        "Pick templates to use:",
        AVAILABLE_TEMPLATES,
        TEMPLATE_DESCRIPTIONS,
    )

    agents_list = []

    # Create agents from templates
    for template in selected_templates:
        name = prompt_str(f"Name for {template} agent", default=template)
        model = _prompt_model(name)
        machine = _prompt_machine(config, name)
        agents_list.append(Agent(
            name=name,
            role=TEMPLATE_DESCRIPTIONS.get(template, ""),
            model=model,
            machine=machine,
            template=template,
        ))

    # Fill remaining with custom
    remaining = num_agents - len(agents_list)
    if remaining > 0:
        print()
        info(f"Define {remaining} more custom agent(s):")
        for i in range(remaining):
            name = prompt_str(f"Custom agent {i + 1} name")
            role = prompt_str(f"Custom agent {i + 1} role")
            model = _prompt_model(name)
            machine = _prompt_machine(config, name)
            agents_list.append(Agent(
                name=name, role=role, model=model, machine=machine,
            ))

    config.agents = agents_list


def _prompt_model(agent_name: str) -> str:
    """Prompt for model selection."""
    idx = prompt_choice(
        f"Model for {agent_name}:",
        [
            "opus (most capable, highest cost)",
            "sonnet (balanced capability and speed)",
            "haiku (fastest, lowest cost)",
        ],
        default=1,  # sonnet default
    )
    return MODEL_OPTIONS[idx]


def _prompt_machine(config: TeamConfig, agent_name: str) -> str:
    """Prompt for machine assignment (only if distributed)."""
    if config.deployment_mode == "single":
        return "local"

    machines = ["local"] + [m.name for m in config.machines]
    if len(machines) == 1:
        return "local"

    idx = prompt_choice(
        f"Machine for {agent_name}:",
        machines,
        default=0,
    )
    return machines[idx]


def step_team_rules(config: TeamConfig) -> None:
    """Step 4: Team rules and behavior."""
    section("Step 4: Team Rules")

    config.team_name = prompt_str("Team name", default="my-team")

    # Validate team name
    config.team_name = re.sub(r"[^a-zA-Z0-9_-]", "-", config.team_name).lower()

    idx = prompt_choice(
        "Boot prompt (what agents do on startup):",
        [
            "Default: Run daily routine then enter proactive mode when idle.",
            "Custom (you type it)",
        ],
        default=0,
    )
    if idx == 1:
        config.boot_prompt = prompt_str("Boot prompt")

    config.stagger_seconds = prompt_int(
        "Stagger delay between agent launches (seconds)",
        default=10,
        min_val=0,
        max_val=120,
    )

    config.enable_guardian = prompt_yn("Enable guardian watchdog?")
    config.enable_courier = prompt_yn("Enable courier messaging?")
    config.enable_idle_shutdown = prompt_yn("Enable idle shutdown?", default=False)

    if config.enable_idle_shutdown:
        config.idle_timeout_minutes = prompt_int(
            "Idle timeout (minutes)",
            default=15,
            min_val=1,
            max_val=120,
        )


def step_policies(config: TeamConfig) -> None:
    """Step 5: Permission and communication policies."""
    section("Step 5: Policies")

    idx = prompt_choice(
        "Permission mode:",
        [
            "bypassPermissions (agents run autonomously — recommended for experienced users)",
            "default (agents ask before actions)",
            "acceptEdits (agents can edit files, ask for other tools)",
        ],
        default=0,
    )
    config.permission_mode = ["bypassPermissions", "default", "acceptEdits"][idx]

    config.agent_memory = prompt_yn("Enable agent memory (agents remember across sessions)?")

    idx = prompt_choice(
        "Communication protocol:",
        [
            "Full (courier + router + broadcasts — recommended)",
            "Basic (file-based inbox only)",
            "None (agents work independently)",
        ],
        default=0,
    )
    config.communication_protocol = ["full", "basic", "none"][idx]


# ── Generation ───────────────────────────────────────────────────────────────

def generate_toml(config: TeamConfig) -> str:
    """Generate a soul-team.toml from the configuration."""
    lines = []
    lines.append("# Soul Team Configuration")
    lines.append(f"# Generated by soul-init on {_now()}")
    lines.append("#")
    lines.append(f'# Team: {config.team_name} ({len(config.agents)} agents, {config.deployment_mode} mode)')
    lines.append("")
    lines.append("[team]")
    lines.append(f'name = "{config.team_name}"')
    lines.append(f'description = "AI agent team — {len(config.agents)} agents"')
    lines.append(f'boot_prompt = "{_escape_toml(config.boot_prompt)}"')
    lines.append(f"stagger_seconds = {config.stagger_seconds}")
    lines.append("")

    lines.append("[policies]")
    lines.append(f'permission_mode = "{config.permission_mode}"')
    lines.append(f"agent_memory = {str(config.agent_memory).lower()}")
    lines.append(f'communication = "{config.communication_protocol}"')
    lines.append(f"guardian = {str(config.enable_guardian).lower()}")
    lines.append(f"courier = {str(config.enable_courier).lower()}")
    lines.append(f"idle_shutdown = {str(config.enable_idle_shutdown).lower()}")
    if config.enable_idle_shutdown:
        lines.append(f"idle_timeout_minutes = {config.idle_timeout_minutes}")
    lines.append("")

    # Machines section (distributed only)
    if config.machines:
        for m in config.machines:
            lines.append("[[machines]]")
            lines.append(f'name = "{m.name}"')
            lines.append(f'ssh = "{m.ssh_target}"')
            lines.append("")

    # Agents
    local_agents = [a for a in config.agents if a.machine == "local"]
    remote_agents = [a for a in config.agents if a.machine != "local"]

    if local_agents:
        lines.append("# --- Local agents ---")
        lines.append("")
    for agent in local_agents:
        lines.append("[[agents]]")
        lines.append(f'name = "{agent.name}"')
        lines.append(f'model = "{agent.model}"')
        lines.append(f'machine = "local"')
        lines.append(f"cgroup = true")
        if agent.template:
            lines.append(f'template = "{agent.template}"')
        lines.append("")

    if remote_agents:
        lines.append("# --- Remote agents ---")
        lines.append("")
    for agent in remote_agents:
        machine_obj = next((m for m in config.machines if m.name == agent.machine), None)
        ssh_target = machine_obj.ssh_target if machine_obj else "user@host"
        lines.append("[[agents]]")
        lines.append(f'name = "{agent.name}"')
        lines.append(f'model = "{agent.model}"')
        lines.append(f'machine = "{agent.machine}"')
        lines.append(f'ssh = "{ssh_target}"')
        lines.append(f"cgroup = false")
        if agent.template:
            lines.append(f'template = "{agent.template}"')
        lines.append("")

    # Layout
    lines.append("# --- Layout ---")
    lines.append("")
    lines.append("[layout]")
    n = len(config.agents)
    cols = 1 if n <= 3 else (2 if n <= 6 else 3)
    rows = (n + cols - 1) // cols
    lines.append(f"columns = {cols + 1}  # CEO + {cols} agent column(s)")
    lines.append(f"rows = {rows}")
    lines.append("")

    # Distribute agents into columns
    columns: list[list[str]] = [[] for _ in range(cols)]
    for i, agent in enumerate(config.agents):
        columns[i % cols].append(agent.name)

    for c, col_agents in enumerate(columns):
        lines.append("[[layout.grid]]")
        lines.append(f"col = {c + 1}")
        agent_names = ", ".join(f'"{a}"' for a in col_agents)
        lines.append(f"agents = [{agent_names}]")
        lines.append("")

    return "\n".join(lines)


def generate_agent_md(agent: Agent) -> str:
    """Generate an agent .md file from template or custom definition."""
    if agent.template:
        template = load_template(agent.template)
        if template:
            return render_template(template, agent.name)

    # Fallback: generate a minimal agent file
    return textwrap.dedent(f"""\
        ---
        name: {agent.name}
        description: {agent.role}
        ---

        # {agent.name.capitalize()} Agent

        You are **{agent.name.capitalize()}** -- {agent.role}.

        ## Mandate

        Execute tasks in your domain. Verify results before claiming done.
        Check inbox at the start of every work cycle.

        ## Communication Style

        - Be concise and evidence-driven
        - Lead with the answer, not the process
        - Escalate blockers immediately to team lead

        ## Daily Routine

        1. Check inbox for new messages
        2. Review open tasks
        3. Work on highest-priority item
        4. When idle: enter proactive mode

        ## Shared Protocols

        See team protocol file for: communication standards, escalation chain,
        heartbeat protocol, task execution flow, and memory persistence.
    """)


def generate_team_protocol(config: TeamConfig) -> str:
    """Generate or copy the team protocol file."""
    if PROTOCOL_SRC.exists():
        content = PROTOCOL_SRC.read_text()
        # Replace soul-team references with the user's team name
        content = content.replace("soul-team", config.team_name)
        return content

    # Minimal fallback protocol
    return textwrap.dedent(f"""\
        # Team Protocol — {config.team_name}

        ## Communication Standard

        Every agent message must be crisp, concise, and precise.
        Lead with action or answer. No preamble. No trailing summaries.

        ## Task Execution Flow

        1. Check inbox for new messages
        2. Process highest-priority task
        3. Update status on completion
        4. Enter proactive mode when idle

        ## Escalation Protocol

        1. Can you solve it yourself? Do it.
        2. Does a peer know? Ask them.
        3. Still blocked? Escalate to team lead.

        ## Team Coordination

        - Inbox: check at start of every cycle
        - Send messages via team messaging system
        - CEO/team-lead requests take immediate priority
    """)


def _escape_toml(s: str) -> str:
    """Escape a string for TOML."""
    return s.replace("\\", "\\\\").replace('"', '\\"').replace("\n", "\\n")


def _now() -> str:
    """ISO date string."""
    from datetime import datetime, timezone
    return datetime.now(timezone.utc).strftime("%Y-%m-%d %H:%M UTC")


# ── File writing ─────────────────────────────────────────────────────────────

def write_config(config: TeamConfig) -> list[str]:
    """Write all generated files. Returns list of created file paths."""
    created: list[str] = []

    section("Generating Configuration")

    # 1. TOML config
    CLAUDE_CONFIG_DIR.mkdir(parents=True, exist_ok=True)
    toml_path = CLAUDE_CONFIG_DIR / f"{config.team_name}.toml"
    toml_content = generate_toml(config)
    toml_path.write_text(toml_content)
    ok(f"Created {toml_path}")
    created.append(str(toml_path))

    # Also write to the standard soul-team.toml location if team name differs
    standard_toml = CLAUDE_CONFIG_DIR / "soul-team.toml"
    if config.team_name != "soul-team":
        standard_toml.write_text(toml_content)
        ok(f"Created {standard_toml} (launcher default)")
        created.append(str(standard_toml))

    # 2. Agent .md files
    CLAUDE_AGENTS_DIR.mkdir(parents=True, exist_ok=True)
    for agent in config.agents:
        agent_path = CLAUDE_AGENTS_DIR / f"{agent.name}.md"
        agent_content = generate_agent_md(agent)
        agent_path.write_text(agent_content)
        ok(f"Created {agent_path}")
        created.append(str(agent_path))

    # 3. Team protocol
    protocol_dir = HOME / ".claude" / "protocols"
    protocol_dir.mkdir(parents=True, exist_ok=True)
    protocol_path = protocol_dir / "team-protocol.md"
    protocol_content = generate_team_protocol(config)
    protocol_path.write_text(protocol_content)
    ok(f"Created {protocol_path}")
    created.append(str(protocol_path))

    # 4. Runtime directories
    runtime_dirs = [
        HOME / ".soul",
        HOME / ".soul" / "preflight",
        HOME / ".soul" / "health",
        HOME / ".clawteam" / "teams" / config.team_name,
        HOME / ".clawteam" / "teams" / config.team_name / "inboxes",
        HOME / ".clawteam" / "teams" / config.team_name / "broadcast",
        HOME / ".clawteam" / "teams" / config.team_name / "discussions",
        HOME / ".clawteam" / "teams" / config.team_name / "sidecar",
        HOME / ".clawteam" / "teams" / config.team_name / "queue",
        CLAUDE_LOGS_DIR,
    ]
    for d in runtime_dirs:
        d.mkdir(parents=True, exist_ok=True)
    ok(f"Created {len(runtime_dirs)} runtime directories")

    # 5. Per-agent inbox directories
    inbox_base = HOME / ".clawteam" / "teams" / config.team_name / "inboxes"
    for agent in config.agents:
        agent_inbox = inbox_base / f"{agent.name}_{agent.name}" / "archive"
        agent_inbox.mkdir(parents=True, exist_ok=True)
    # Team lead inbox
    (inbox_base / "team-lead_team-lead" / "archive").mkdir(parents=True, exist_ok=True)
    ok(f"Created inbox directories for {len(config.agents)} agents + team-lead")

    # 6. Native Teams inbox files
    native_inbox = HOME / ".claude" / "teams" / config.team_name / "inboxes"
    native_inbox.mkdir(parents=True, exist_ok=True)
    for agent in config.agents:
        inbox_file = native_inbox / f"{agent.name}.json"
        if not inbox_file.exists():
            inbox_file.write_text("[]")
    tl_file = native_inbox / "team-lead.json"
    if not tl_file.exists():
        tl_file.write_text("[]")
    ok("Initialized native inbox files")

    # 7. Systemd services (if available)
    systemd_user = HOME / ".config" / "systemd" / "user"
    if SYSTEMD_SRC.exists() and _has_systemd():
        systemd_user.mkdir(parents=True, exist_ok=True)
        installed = 0
        for svc_file in SYSTEMD_SRC.glob("*.service"):
            dest = systemd_user / svc_file.name
            shutil.copy2(svc_file, dest)
            installed += 1
        if installed > 0:
            subprocess.run(["systemctl", "--user", "daemon-reload"], capture_output=True)
            ok(f"Installed {installed} systemd service(s)")
            created.append(str(systemd_user))
        else:
            warn("No .service files found in repo systemd directory")
    else:
        warn("systemd not available -- daemons will start manually via soul-team CLI")

    return created


def _has_systemd() -> bool:
    """Check if systemd user session is available."""
    try:
        result = subprocess.run(
            ["systemctl", "--user", "status"],
            capture_output=True, timeout=5,
        )
        return result.returncode in (0, 3)  # 3 = no units running, but session exists
    except (FileNotFoundError, subprocess.TimeoutExpired):
        return False


# ── Quick start ──────────────────────────────────────────────────────────────

def quick_start(num_agents: int = 3) -> TeamConfig:
    """Generate a quick-start config with no prompts."""
    config = TeamConfig()
    config.team_name = "my-team"

    # Rotate through templates
    for i in range(num_agents):
        template = AVAILABLE_TEMPLATES[i % len(AVAILABLE_TEMPLATES)]
        name = template if i < len(AVAILABLE_TEMPLATES) else f"{template}{i + 1}"

        # Determine model from template defaults
        template_path = TEMPLATES_DIR / f"{template}.md"
        model = "sonnet"
        if template_path.exists():
            content = template_path.read_text()
            m = re.search(r"model_default:\s*(\w+)", content)
            if m:
                model = m.group(1)

        config.agents.append(Agent(
            name=name,
            role=TEMPLATE_DESCRIPTIONS.get(template, f"{template} agent"),
            model=model,
            machine="local",
            template=template,
        ))

    return config


# ── Summary ──────────────────────────────────────────────────────────────────

def print_summary(config: TeamConfig, created: list[str]) -> None:
    """Print final summary and next steps."""
    print()
    print(f"{GREEN}{'=' * 60}{NC}")
    print(f"{GREEN}  soul-team configured successfully!{NC}")
    print(f"{GREEN}{'=' * 60}{NC}")
    print()

    # Agent roster
    info("Agent Roster:")
    print(f"    {'NAME':<16} {'MODEL':<10} {'MACHINE':<12} {'TEMPLATE'}")
    print(f"    {'─' * 15} {'─' * 9} {'─' * 11} {'─' * 12}")
    for a in config.agents:
        tmpl = a.template or "(custom)"
        print(f"    {a.name:<16} {a.model:<10} {a.machine:<12} {tmpl}")
    print()

    # Settings
    info("Settings:")
    print(f"    Team name:       {config.team_name}")
    print(f"    Deployment:      {config.deployment_mode}")
    print(f"    Permissions:     {config.permission_mode}")
    print(f"    Communication:   {config.communication_protocol}")
    print(f"    Guardian:        {'on' if config.enable_guardian else 'off'}")
    print(f"    Courier:         {'on' if config.enable_courier else 'off'}")
    print(f"    Agent memory:    {'on' if config.agent_memory else 'off'}")
    print(f"    Stagger delay:   {config.stagger_seconds}s")
    print()

    # Next steps
    info("Next steps:")
    print()
    print(f"    1. Review your config:")
    print(f"       {BOLD}{CLAUDE_CONFIG_DIR / f'{config.team_name}.toml'}{NC}")
    print()
    print(f"    2. Review agent personas:")
    print(f"       {BOLD}{CLAUDE_AGENTS_DIR}/{NC}")
    print()
    print(f"    3. Launch your team:")
    print(f"       {BOLD}soul-team{NC}")
    print()
    print(f"    4. Send a message to an agent:")
    print(f"       {BOLD}soul-msg send <agent-name> \"Hello from the terminal\"{NC}")
    print()


# ── Main ─────────────────────────────────────────────────────────────────────

def handle_sigint(signum: int, frame) -> None:
    """Handle Ctrl+C gracefully."""
    print(f"\n\n{YELLOW}  Setup cancelled. No files were written.{NC}\n")
    sys.exit(130)


def main() -> None:
    signal.signal(signal.SIGINT, handle_sigint)

    parser = argparse.ArgumentParser(
        description="soul-team init — interactive setup wizard",
        formatter_class=argparse.RawDescriptionHelpFormatter,
    )
    parser.add_argument(
        "--quick", action="store_true",
        help="Quick start with defaults (no prompts)",
    )
    parser.add_argument(
        "-n", "--num-agents", type=int, default=3,
        help="Number of agents for --quick mode (default: 3)",
    )
    parser.add_argument(
        "--config", type=str, default=None,
        help="Path to existing TOML to edit (re-run mode)",
    )

    args = parser.parse_args()

    banner()

    if args.quick:
        # Quick start — no prompts
        info(f"Quick start: creating {args.num_agents}-agent team with defaults...")
        print()
        config = quick_start(args.num_agents)
        created = write_config(config)
        print_summary(config, created)
        return

    # Interactive wizard
    print(f"  {DIM}Answer each question to configure your team.{NC}")
    print(f"  {DIM}Press Enter to accept [defaults]. Ctrl+C to cancel.{NC}")

    config = TeamConfig()

    # Step 1: Deployment mode
    step_deployment_mode(config)

    # Step 2: Agents (we need agents before machines so we can assign them)
    step_agents(config)

    # Step 3: Machines (distributed only — after agents so we know what to assign)
    if config.deployment_mode == "distributed":
        step_machines(config)
        # Re-assign agents to machines if needed
        if config.machines:
            section("Agent Machine Assignment")
            info("Assign agents to machines:")
            machine_names = ["local"] + [m.name for m in config.machines]
            for agent in config.agents:
                if agent.machine == "local":
                    idx = prompt_choice(
                        f"Machine for {agent.name}:",
                        machine_names,
                        default=0,
                    )
                    agent.machine = machine_names[idx]

    # Step 4: Team rules
    step_team_rules(config)

    # Step 5: Policies
    step_policies(config)

    # Generate everything
    created = write_config(config)
    print_summary(config, created)


if __name__ == "__main__":
    main()
