#!/usr/bin/env python3
"""
soul-init — DEPRECATED: redirects to soul-team.

All setup wizard and management functionality has been unified into the
single 'soul-team' command. This stub exists for backward compatibility.

Usage:
    soul-init           ->  soul-team init
    soul-init --quick   ->  soul-team init --quick
    soul-init add-agent ->  soul-team add-agent
"""

import os
import sys
from pathlib import Path

SCRIPT_DIR = Path(__file__).resolve().parent
SOUL_TEAM = str(SCRIPT_DIR / "soul-team")


def main() -> None:
    print("\033[1;33m  [!!] soul-init is deprecated. Use 'soul-team' instead.\033[0m")
    print(f"  Redirecting to: soul-team {' '.join(sys.argv[1:])}")
    print()

    args = sys.argv[1:]

    # If called with no args or just --quick/-n, prepend 'init'
    if not args or args[0].startswith("-"):
        args = ["init"] + args

    os.execvp("python3", ["python3", SOUL_TEAM] + args)


if __name__ == "__main__":
    main()
