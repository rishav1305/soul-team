    "pm": "Product management, roadmap",
    "designer": "UI/UX, wireframes, design systems",
    "devops": "CI/CD, Docker, monitoring",
    "qa": "Testing, E2E, bug triage",
    "data-engineer": "Pipelines, ETL, warehousing",
    "security": "Vulnerability scanning, compliance",
    "marketer": "Campaigns, SEO, growth",
    "sales": "Outreach, pipeline, CRM",
    "coach": "Interview prep, learning",
    "finance": "Budgeting, forecasting",
}

QUICK_START_TEMPLATES = ["developer", "researcher", "assistant"]
MODEL_OPTIONS = ["opus", "sonnet", "haiku"]


@dataclass
class Machine:
    """A remote machine for distributed deployment."""
    name: str
    ssh_target: str
    verified: bool = False


@dataclass
class Agent:
    """An agent definition."""
    name: str
    role: str
    model: str = "sonnet"
    machine: str = "local"
    template: Optional[str] = None
    cgroup: bool = True


@dataclass
class TeamConfig:
    """Full team configuration."""
    team_name: str = "my-team"
    deployment_mode: str = "single"
    boot_prompt: str = "Run your daily routine then enter proactive mode when idle."
    stagger_seconds: int = 10
    enable_guardian: bool = True
    enable_courier: bool = True
    enable_idle_shutdown: bool = False
    idle_timeout_minutes: int = 15
    permission_mode: str = "bypassPermissions"
    agent_memory: bool = True
    communication_protocol: str = "full"
    agents: list[Agent] = field(default_factory=list)
    machines: list[Machine] = field(default_factory=list)


# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# CONFIG RESOLUTION & TOML I/O
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

def _resolve_config_path() -> Path:
    """Resolve the active config file path."""
    env_val = os.environ.get("SOUL_TEAM_CONFIG")
    if env_val:
        p = Path(env_val)
        if p.exists():
            return p
    primary = USER_CONFIG_DIR / "config.toml"
    if primary.exists():
        return primary
    legacy = CLAUDE_CONFIG_DIR / "soul-team.toml"
    if legacy.exists():
        return legacy
    return primary  # Default write target


def _load_toml(path: Path) -> dict:
    """Load a TOML file using stdlib tomllib."""
    import tomllib
    with open(path, "rb") as f:
        return tomllib.load(f)


def _escape_toml(s: str) -> str:
    """Escape a string for TOML."""
    return s.replace("\\", "\\\\").replace('"', '\\"').replace("\n", "\\n")


def _toml_value(v) -> str:
    """Format a Python value as a TOML value."""
    if isinstance(v, bool):
        return "true" if v else "false"
    if isinstance(v, int):
        return str(v)
    if isinstance(v, str):
        return f'"{_escape_toml(v)}"'
    if isinstance(v, list):
        items = ", ".join(_toml_value(i) for i in v)
        return f"[{items}]"
    return f'"{v}"'


def _save_toml_from_dict(data: dict, path: Path) -> None:
    """Write a dict back as TOML (minimal serializer since stdlib has no dump)."""
    lines: list[str] = []
    lines.append("# Soul Team Configuration")
    lines.append(f"# Modified by soul-team on {_now()}")
    lines.append("")

    team = data.get("team", {})
    if team:
        lines.append("[team]")
        for k, v in team.items():
            lines.append(f'{k} = {_toml_value(v)}')
        lines.append("")

    policies = data.get("policies", {})
    if policies:
        lines.append("[policies]")
        for k, v in policies.items():
            lines.append(f'{k} = {_toml_value(v)}')
        lines.append("")

    machines = data.get("machines", [])
    for m in machines:
        lines.append("[[machines]]")
        for k, v in m.items():
            lines.append(f'{k} = {_toml_value(v)}')
        lines.append("")

    agents = data.get("agents", [])
    for agent in agents:
        lines.append("[[agents]]")
        for k, v in agent.items():
            lines.append(f'{k} = {_toml_value(v)}')
        lines.append("")

    layout = data.get("layout", {})
    if layout:
        grid = layout.pop("grid", [])
        lines.append("[layout]")
        for k, v in layout.items():
            lines.append(f'{k} = {_toml_value(v)}')
        lines.append("")
        for g in grid:
            lines.append("[[layout.grid]]")
            for k, v in g.items():
                lines.append(f'{k} = {_toml_value(v)}')
            lines.append("")

    path.parent.mkdir(parents=True, exist_ok=True)
    path.write_text("\n".join(lines) + "\n")


def _now() -> str:
    return datetime.now(timezone.utc).strftime("%Y-%m-%d %H:%M UTC")


def _recalculate_layout(data: dict) -> None:
    """Recalculate layout section based on current agents."""
    agents = data.get("agents", [])
    n = len(agents)
    if n == 0:
        data.pop("layout", None)
        return
    cols = 1 if n <= 3 else (2 if n <= 6 else 3)
    rows = (n + cols - 1) // cols

    columns: list[list[str]] = [[] for _ in range(cols)]
    for i, agent in enumerate(agents):
        columns[i % cols].append(agent.get("name", f"agent-{i}"))

    grid = []
    for c, col_agents in enumerate(columns):
        grid.append({"col": c + 1, "agents": col_agents})

    data["layout"] = {"columns": cols + 1, "rows": rows, "grid": grid}


# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# STATE DETECTION
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

def detect_state() -> tuple[str, dict | None]:
    """Detect current state. Returns (state, config_data).

    States: "first_run", "configured", "running"
    """
    config_path = _resolve_config_path()
    config_exists = config_path.exists()
    config_data = None

    if config_exists:
        try:
            config_data = _load_toml(config_path)
        except Exception:
            config_data = None

    if not config_exists or config_data is None:
        return "first_run", None

    # Check if a tmux session is running
    team_name = config_data.get("team", {}).get("name", "soul-team")
    session_running = subprocess.run(
        ["tmux", "has-session", "-t", team_name],
        capture_output=True,
    ).returncode == 0

    if session_running:
        return "running", config_data
    else:
        return "configured", config_data


def _get_session_uptime(team_name: str) -> str:
    """Get how long the tmux session has been running."""
    try:
        result = subprocess.run(
            ["tmux", "display-message", "-t", team_name, "-p", "#{session_created}"],
            capture_output=True, text=True,
        )
        if result.returncode == 0 and result.stdout.strip():
            created = int(result.stdout.strip())
            elapsed = int(time.time()) - created
            hours = elapsed // 3600
            minutes = (elapsed % 3600) // 60
            if hours > 0:
                return f"{hours}h {minutes}m"
            return f"{minutes}m"
    except Exception:
        pass
    return "unknown"


def _count_running_agents(team_name: str) -> tuple[int, int]:
    """Count (alive, total) agents by checking tmux panes."""
    panes_json = HOME / ".clawteam" / "teams" / team_name / "panes.json"
    if not panes_json.exists():
        return 0, 0

    try:
        panes = json.loads(panes_json.read_text())
    except Exception:
        return 0, 0

    total = 0
    alive = 0
    for agent_name, pane_id in panes.items():
        if agent_name == "team-lead":
            continue
        total += 1
        try:
            result = subprocess.run(
                ["tmux", "capture-pane", "-p", "-t", pane_id, "-S", "-3"],
                capture_output=True, text=True,
            )
            content = result.stdout.strip()
            # If pane has content and not just a shell prompt, agent is alive
            if content and not re.match(r'^[a-z]+@[a-zA-Z0-9-]+[^>]*\$\s*$', content):
                alive += 1
        except Exception:
            pass

    return alive, total


# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# TEMPLATE & AGENT GENERATION (from soul-init)
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

def load_template(template_name: str) -> str:
    path = TEMPLATES_DIR / f"{template_name}.md"
    if not path.exists():
        return ""
    return path.read_text()


def render_template(template_content: str, agent_name: str) -> str:
    return template_content.replace("{{AGENT_NAME}}", agent_name.capitalize())


def _get_template_model_default(template_name: Optional[str]) -> str:
    if not template_name:
        return "sonnet"
    path = TEMPLATES_DIR / f"{template_name}.md"
    if not path.exists():
        return "sonnet"
    try:
        content = path.read_text()
        m = re.search(r"model_default:\s*(\w+)", content)
        if m:
            return m.group(1)
    except OSError:
        pass
    return "sonnet"


def generate_agent_md(agent: Agent) -> str:
    if agent.template:
        template = load_template(agent.template)
        if template:
            return render_template(template, agent.name)
    return textwrap.dedent(f"""\
        ---
        name: {agent.name}
        description: {agent.role}
        ---

        # {agent.name.capitalize()} Agent

        You are **{agent.name.capitalize()}** -- {agent.role}.

        ## Mandate

        Execute tasks in your domain. Verify results before claiming done.
        Check inbox at the start of every work cycle.

        ## Communication Style

        - Be concise and evidence-driven
        - Lead with the answer, not the process
        - Escalate blockers immediately to team lead

        ## Daily Routine

        1. Check inbox for new messages
        2. Review open tasks
        3. Work on highest-priority item
        4. When idle: enter proactive mode

        ## Shared Protocols

        See team protocol file for: communication standards, escalation chain,
        heartbeat protocol, task execution flow, and memory persistence.
    """)


def generate_toml(config: TeamConfig) -> str:
    lines = []
    lines.append("# Soul Team Configuration")
    lines.append(f"# Generated by soul-team on {_now()}")
    lines.append("")
    lines.append("[team]")
    lines.append(f'name = "{config.team_name}"')
    lines.append(f'description = "AI agent team -- {len(config.agents)} agents"')
    lines.append(f'boot_prompt = "{_escape_toml(config.boot_prompt)}"')
    lines.append(f"stagger_seconds = {config.stagger_seconds}")
    lines.append("")

    lines.append("[policies]")
    lines.append(f'permission_mode = "{config.permission_mode}"')
    lines.append(f"agent_memory = {str(config.agent_memory).lower()}")
    lines.append(f'communication = "{config.communication_protocol}"')
    lines.append(f"guardian = {str(config.enable_guardian).lower()}")
    lines.append(f"courier = {str(config.enable_courier).lower()}")
    lines.append(f"idle_shutdown = {str(config.enable_idle_shutdown).lower()}")
    if config.enable_idle_shutdown:
        lines.append(f"idle_timeout_minutes = {config.idle_timeout_minutes}")
    lines.append("")

    if config.machines:
        for m in config.machines:
            lines.append("[[machines]]")
            lines.append(f'name = "{m.name}"')
            lines.append(f'ssh = "{m.ssh_target}"')
            lines.append("")

    local_agents = [a for a in config.agents if a.machine == "local"]
    remote_agents = [a for a in config.agents if a.machine != "local"]

    if local_agents:
        lines.append("# --- Local agents ---")
        lines.append("")
    for agent in local_agents:
        lines.append("[[agents]]")
        lines.append(f'name = "{agent.name}"')
        lines.append(f'model = "{agent.model}"')
        lines.append(f'machine = "local"')
        lines.append(f"cgroup = true")
        if agent.template:
            lines.append(f'template = "{agent.template}"')
        lines.append("")

    if remote_agents:
        lines.append("# --- Remote agents ---")
        lines.append("")
    for agent in remote_agents:
        machine_obj = next((m for m in config.machines if m.name == agent.machine), None)
        ssh_target = machine_obj.ssh_target if machine_obj else "user@host"
        lines.append("[[agents]]")
        lines.append(f'name = "{agent.name}"')
        lines.append(f'model = "{agent.model}"')
        lines.append(f'machine = "{agent.machine}"')
        lines.append(f'ssh = "{ssh_target}"')
        lines.append(f"cgroup = false")
        if agent.template:
            lines.append(f'template = "{agent.template}"')
        lines.append("")

    lines.append("[layout]")
    n = len(config.agents)
    cols = 1 if n <= 3 else (2 if n <= 6 else 3)
    rows = (n + cols - 1) // cols
    lines.append(f"columns = {cols + 1}")
    lines.append(f"rows = {rows}")
    lines.append("")

    columns: list[list[str]] = [[] for _ in range(cols)]
    for i, agent in enumerate(config.agents):
        columns[i % cols].append(agent.name)
    for c, col_agents in enumerate(columns):
        lines.append("[[layout.grid]]")
        lines.append(f"col = {c + 1}")
        agent_names = ", ".join(f'"{a}"' for a in col_agents)
        lines.append(f"agents = [{agent_names}]")
        lines.append("")

    return "\n".join(lines)


def generate_team_protocol(config: TeamConfig) -> str:
    if PROTOCOL_SRC.exists():
        content = PROTOCOL_SRC.read_text()
        content = content.replace("soul-team", config.team_name)
        return content
    return textwrap.dedent(f"""\
        # Team Protocol -- {config.team_name}

        ## Communication Standard

        Every agent message must be crisp, concise, and precise.
        Lead with action or answer. No preamble. No trailing summaries.

        ## Task Execution Flow

        1. Check inbox for new messages
        2. Process highest-priority task
        3. Update status on completion
        4. Enter proactive mode when idle

        ## Escalation Protocol

        1. Can you solve it yourself? Do it.
        2. Does a peer know? Ask them.
        3. Still blocked? Escalate to team lead.
    """)


def test_ssh(target: str) -> bool:
    try:
        result = subprocess.run(
            ["ssh", "-o", "ConnectTimeout=5", "-o", "BatchMode=yes", target, "echo ok"],
            capture_output=True, text=True, timeout=10,
        )
        return result.returncode == 0 and "ok" in result.stdout
    except (subprocess.TimeoutExpired, FileNotFoundError):
        return False


def _has_systemd() -> bool:
    try:
        result = subprocess.run(
            ["systemctl", "--user", "status"],
            capture_output=True, timeout=5,
        )
        return result.returncode in (0, 3)
    except (FileNotFoundError, subprocess.TimeoutExpired):
        return False


# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# CONFIG WRITING (generates all files from a TeamConfig)
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

def write_config(config: TeamConfig) -> list[str]:
    """Write all generated files. Returns list of created file paths."""
    created: list[str] = []

    section_header("Generating Configuration")

    # 1. TOML config
    USER_CONFIG_DIR.mkdir(parents=True, exist_ok=True)
    toml_content = generate_toml(config)
    primary_toml = USER_CONFIG_DIR / "config.toml"
    primary_toml.write_text(toml_content)
    ok(f"Config: {primary_toml}")
    created.append(str(primary_toml))

    # Legacy compat
    CLAUDE_CONFIG_DIR.mkdir(parents=True, exist_ok=True)
    legacy_toml = CLAUDE_CONFIG_DIR / "soul-team.toml"
    legacy_toml.write_text(toml_content)
    created.append(str(legacy_toml))

    # 2. Agent .md files
    CLAUDE_AGENTS_DIR.mkdir(parents=True, exist_ok=True)
    for agent in config.agents:
        agent_path = CLAUDE_AGENTS_DIR / f"{agent.name}.md"
        agent_content = generate_agent_md(agent)
        agent_path.write_text(agent_content)
        created.append(str(agent_path))
    ok(f"Agent personas: {len(config.agents)} files")

    # 3. Team protocol
    protocol_dir = HOME / ".claude" / "protocols"
    protocol_dir.mkdir(parents=True, exist_ok=True)
    protocol_path = protocol_dir / "team-protocol.md"
    protocol_content = generate_team_protocol(config)
    protocol_path.write_text(protocol_content)
    created.append(str(protocol_path))
    ok(f"Protocol: {protocol_path}")

    # 4. Runtime directories
    runtime_dirs = [
        HOME / ".soul", HOME / ".soul" / "preflight", HOME / ".soul" / "health",
        HOME / ".clawteam" / "teams" / config.team_name,
        HOME / ".clawteam" / "teams" / config.team_name / "inboxes",
        HOME / ".clawteam" / "teams" / config.team_name / "broadcast",
        HOME / ".clawteam" / "teams" / config.team_name / "discussions",
        HOME / ".clawteam" / "teams" / config.team_name / "sidecar",
        HOME / ".clawteam" / "teams" / config.team_name / "queue",
        CLAUDE_LOGS_DIR,
    ]
    for d in runtime_dirs:
        d.mkdir(parents=True, exist_ok=True)
    ok(f"Runtime directories: {len(runtime_dirs)}")

    # 5. Per-agent inbox directories
    inbox_base = HOME / ".clawteam" / "teams" / config.team_name / "inboxes"
    for agent in config.agents:
        (inbox_base / f"{agent.name}_{agent.name}" / "archive").mkdir(parents=True, exist_ok=True)
    (inbox_base / "team-lead_team-lead" / "archive").mkdir(parents=True, exist_ok=True)

    # 6. Native Teams inbox files
    native_inbox = HOME / ".claude" / "teams" / config.team_name / "inboxes"
    native_inbox.mkdir(parents=True, exist_ok=True)
    for agent in config.agents:
        inbox_file = native_inbox / f"{agent.name}.json"
        if not inbox_file.exists():
            inbox_file.write_text("[]")
    tl_file = native_inbox / "team-lead.json"
    if not tl_file.exists():
        tl_file.write_text("[]")
    ok("Inbox files initialized")

    # 7. Systemd services
    systemd_user = HOME / ".config" / "systemd" / "user"
    if SYSTEMD_SRC.exists() and _has_systemd():
        systemd_user.mkdir(parents=True, exist_ok=True)
        installed = 0
        for svc_file in SYSTEMD_SRC.glob("*.service"):
            dest = systemd_user / svc_file.name
            shutil.copy2(svc_file, dest)
            installed += 1
        if installed > 0:
            subprocess.run(["systemctl", "--user", "daemon-reload"], capture_output=True)
            ok(f"Systemd services: {installed}")
            created.append(str(systemd_user))
    else:
        warn("systemd not available -- daemons will start manually")

    return created


# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# FIRST RUN: SETUP WIZARD
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

def flow_first_run(quick: bool = False, num_agents: int = 3) -> bool:
    """First-run setup wizard. Returns True if user wants to launch after setup."""
    print(f"  Welcome! Let's set up your first agent team.")
    print()

    if quick:
        info(f"Quick start: creating {num_agents}-agent team with defaults...")
        print()
        config = _quick_start_config(num_agents)
        write_config(config)
        _print_roster(config)
        return confirm("Launch now?")

    # Ask: Quick or Custom?
    choice = select_menu(
        "Quick setup or custom?",
        [
            "Quick start",
            "Custom setup",
            "Import config",
        ],
        descriptions=[
            "3 agents, ready in 30 seconds",
            "choose agents, machines, and rules",
            "load an existing soul-team.toml",
        ],
        default=0,
    )

    if choice == 0:
        config = _quick_start_config(3)
        write_config(config)
        _print_roster(config)
        return confirm("Launch now?")

    if choice == 2:
        # Import existing config
        path = text_input("Path to soul-team.toml")
        p = Path(path).expanduser()
        if not p.exists():
            fail(f"File not found: {path}")
            return False
        # Copy to config dir
        USER_CONFIG_DIR.mkdir(parents=True, exist_ok=True)
        dest = USER_CONFIG_DIR / "config.toml"
        shutil.copy2(p, dest)
        ok(f"Imported config to {dest}")
        return confirm("Launch now?")

    # Full custom wizard
    config = _custom_wizard()
    write_config(config)
    _print_roster(config)
    return confirm("Launch now?")


def _quick_start_config(num_agents: int) -> TeamConfig:
    config = TeamConfig()
    config.team_name = "my-team"
    for i in range(num_agents):
        template = AVAILABLE_TEMPLATES[i % len(AVAILABLE_TEMPLATES)]
        name = template if i < len(AVAILABLE_TEMPLATES) else f"{template}{i + 1}"
        model = _get_template_model_default(template)
        config.agents.append(Agent(
            name=name, role=TEMPLATE_DESCRIPTIONS.get(template, ""),
            model=model, machine="local", template=template,
        ))
    return config


def _custom_wizard() -> TeamConfig:
    config = TeamConfig()

    # Step 1: Deployment mode
    section_header("Deployment")
    idx = select_menu(
        "How will you run your agents?",
        ["Single machine (all agents run locally)",
         "Distributed (agents across multiple machines via SSH)"],
    )
    config.deployment_mode = "single" if idx == 0 else "distributed"

    # Step 2: Agents
    section_header("Agents")
    num_agents = number_input("How many agents?", default=3, min_val=1, max_val=20)

    template_indices = multi_select(
        f"Pick agent templates (pick {num_agents} or fewer):",
        AVAILABLE_TEMPLATES,
        [TEMPLATE_DESCRIPTIONS.get(t, "") for t in AVAILABLE_TEMPLATES],
    )

    selected_templates = [AVAILABLE_TEMPLATES[i] for i in template_indices]
    if not selected_templates:
        selected_templates = QUICK_START_TEMPLATES[:num_agents]
        warn(f"No selection -- using defaults: {', '.join(selected_templates)}")

    agents_list = []
    for i in range(num_agents):
        template = selected_templates[i % len(selected_templates)]
        default_name = template if i < len(selected_templates) else f"{template}{i + 1}"
        existing = [a.name for a in agents_list]
        if default_name in existing:
            suffix = 2
            while f"{template}{suffix}" in existing:
                suffix += 1
            default_name = f"{template}{suffix}"

        name = text_input(f"Agent {i + 1} name (template: {template})", default=default_name)

        # Model selection
        template_default = _get_template_model_default(template)
        default_idx = MODEL_OPTIONS.index(template_default) if template_default in MODEL_OPTIONS else 1
        midx = select_menu(
            f"Model for {name}:",
            ["opus (most capable, highest cost)", "sonnet (balanced)", "haiku (fastest, lowest cost)"],
            default=default_idx,
        )
        model = MODEL_OPTIONS[midx]

        machine = "local"
        if config.deployment_mode == "distributed" and config.machines:
            machine_names = ["local"] + [m.name for m in config.machines]
            machine_idx = select_menu(f"Machine for {name}:", machine_names)
            machine = machine_names[machine_idx]

        agents_list.append(Agent(
            name=name, role=TEMPLATE_DESCRIPTIONS.get(template, ""),
            model=model, machine=machine, template=template,
        ))

    config.agents = agents_list

    # Step 3: Machines (distributed only)
    if config.deployment_mode == "distributed":
        section_header("Remote Machines")
        while True:
            mname = text_input("Machine name (e.g. worker-1)")
            ssh_target = text_input(f"SSH target for '{mname}' (user@host)")
            verified = False
            if confirm("Test SSH connection?", default=True):
                print(f"    Testing {ssh_target}...", end=" ", flush=True)
                if test_ssh(ssh_target):
                    print(f"{GREEN}Connected{NC}")
                    verified = True
                else:
                    print(f"{RED}Failed{NC}")
            config.machines.append(Machine(name=mname, ssh_target=ssh_target, verified=verified))
            if not confirm("Add another machine?", default=False):
                break

    # Step 4: Team rules
    section_header("Team Rules")
    config.team_name = text_input("Team name", default="my-team")
    config.team_name = re.sub(r"[^a-zA-Z0-9_-]", "-", config.team_name).lower()
    config.stagger_seconds = number_input("Stagger delay between launches (seconds)", default=10, min_val=0, max_val=120)
    config.enable_guardian = confirm("Enable guardian watchdog?")
    config.enable_courier = confirm("Enable courier messaging?")

    # Step 5: Policies
    section_header("Policies")
    pidx = select_menu(
        "Permission mode:",
        ["bypassPermissions (autonomous)", "default (ask before actions)", "acceptEdits (edit files, ask for tools)"],
    )
    config.permission_mode = ["bypassPermissions", "default", "acceptEdits"][pidx]
    config.agent_memory = confirm("Enable agent memory (persist across sessions)?")
    cidx = select_menu(
        "Communication protocol:",
        ["Full (courier + router + broadcasts)", "Basic (file-based inbox only)", "None (independent)"],
    )
    config.communication_protocol = ["full", "basic", "none"][cidx]

    return config


def _print_roster(config: TeamConfig) -> None:
    """Print agent roster summary with box-drawn table."""
    print()
    section_header("Agent Roster")

    # Column widths
    cw = {"name": 16, "model": 10, "machine": 12, "template": 14}

    # Header
    print(f"  {BOLD}{'NAME':<{cw['name']}} {'MODEL':<{cw['model']}} {'MACHINE':<{cw['machine']}} {'TEMPLATE'}{NC}")
    total_w = cw["name"] + cw["model"] + cw["machine"] + cw["template"]
    print(f"  {GRAY}{BOX_H * total_w}{NC}")

    for a in config.agents:
        tmpl = a.template or "(custom)"
        model_color = CYAN if a.model == "opus" else (GREEN if a.model == "sonnet" else DIM)
        print(f"  {a.name:<{cw['name']}} {model_color}{a.model:<{cw['model']}}{NC} {a.machine:<{cw['machine']}} {DIM}{tmpl}{NC}")
    print()


# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# CONFIGURED STATE: LAUNCH / CONFIGURE MENU
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

def flow_configured(data: dict) -> None:
    """State 2: Config exists, no session running."""
    while True:
        choice = select_menu(
            "What would you like to do?",
            [
                "Launch team",
                "Configure",
                "Validate (dry-run)",
                "Exit",
            ],
            descriptions=[
                "Start all agents in tmux",
                "Modify agents, machines, policies",
                "Check config without launching",
                "",
            ],
        )

        if choice == 0:
            _launch_team(data)
            return
        elif choice == 1:
            _configure_menu(data)
        elif choice == 2:
            _dry_run(data)
        elif choice == 3:
            print()
            hint("Session not started. Run 'soul-team' to return.")
            return


def _configure_menu(data: dict) -> None:
    """Configuration sub-menu."""
    while True:
        choice = select_menu(
            "What to configure?",
            [
                "Agents (add, remove, change model)",
                "Machines (add, remove, test SSH)",
                "Team rules (boot prompt, stagger, timeouts)",
                "Policies (permissions, memory, communication)",
                "View current config",
            ],
            back_option=True,
        )

        if choice == -1:
            return
        elif choice == 0:
            _configure_agents(data)
        elif choice == 1:
            _configure_machines(data)
        elif choice == 2:
            _configure_rules(data)
        elif choice == 3:
            _configure_policies(data)
        elif choice == 4:
            _view_config(data)


def _configure_agents(data: dict) -> None:
    """Agent management sub-menu."""
    config_path = _resolve_config_path()

    while True:
        agents = data.get("agents", [])
        print()
        info("Current agents:")
        for i, a in enumerate(agents):
            model = a.get("model", "sonnet")
            machine = a.get("machine", "local")
            print(f"    {i + 1}. {BOLD}{a['name']}{NC}  [{model}]  {machine}")
        print()

        choice = select_menu(
            "What to do?",
            ["Add agent", "Remove agent", "Change agent model", "Change agent machine"],
            back_option=True,
        )

        if choice == -1:
            return
        elif choice == 0:
            # Add agent from template
            template_idx = select_menu(
                "Choose a template:",
                AVAILABLE_TEMPLATES + ["[custom]"],
                [TEMPLATE_DESCRIPTIONS.get(t, "") for t in AVAILABLE_TEMPLATES] + ["Define from scratch"],
            )

            if template_idx == len(AVAILABLE_TEMPLATES):
                # Custom agent
                name = text_input("Agent name")
                role = text_input("Agent role")
                midx = select_menu("Model:", ["opus", "sonnet", "haiku"], default=1)
                model = MODEL_OPTIONS[midx]
                entry = {"name": name, "model": model, "machine": "local", "cgroup": True}
            else:
                template = AVAILABLE_TEMPLATES[template_idx]
                existing_names = {a["name"] for a in agents}
                name = template
                suffix = 1
                while name in existing_names:
                    suffix += 1
                    name = f"{template}-{suffix}"

                model = _get_template_model_default(template)
                entry = {"name": name, "model": model, "machine": "local", "cgroup": True, "template": template}

                # Generate agent .md
                agent_obj = Agent(name=name, role=TEMPLATE_DESCRIPTIONS.get(template, ""), model=model, template=template)
                CLAUDE_AGENTS_DIR.mkdir(parents=True, exist_ok=True)
                (CLAUDE_AGENTS_DIR / f"{name}.md").write_text(generate_agent_md(agent_obj))

            agents.append(entry)
            _recalculate_layout(data)
            _save_toml_from_dict(data, config_path)
            ok(f"Added {entry['name']} [{entry['model']}]")

        elif choice == 1:
            # Remove agent
            if not agents:
                warn("No agents to remove.")
                continue
            names = [a["name"] for a in agents]
            ridx = select_menu("Remove which agent?", names, back_option=True)
            if ridx == -1:
                continue
            removed = names[ridx]
            data["agents"] = [a for a in agents if a["name"] != removed]
            _recalculate_layout(data)
            _save_toml_from_dict(data, config_path)
            agent_md = CLAUDE_AGENTS_DIR / f"{removed}.md"
            if agent_md.exists():
                agent_md.unlink()
            ok(f"Removed {removed}")

        elif choice == 2:
            # Change model
            if not agents:
                warn("No agents configured.")
                continue
            names = [f"{a['name']} [{a.get('model', 'sonnet')}]" for a in agents]
            aidx = select_menu("Change model for:", names, back_option=True)
            if aidx == -1:
                continue
            midx = select_menu("New model:", ["opus", "sonnet", "haiku"])
            agents[aidx]["model"] = MODEL_OPTIONS[midx]
            _save_toml_from_dict(data, config_path)
            ok(f"Set {agents[aidx]['name']} model to {MODEL_OPTIONS[midx]}")

        elif choice == 3:
            # Change machine
            if not agents:
                warn("No agents configured.")
                continue
            machines_data = data.get("machines", [])
            machine_names = ["local"] + [m.get("name", "?") for m in machines_data]
            if len(machine_names) == 1:
                warn("Only local machine available. Add machines first.")
                continue
            names = [f"{a['name']} [{a.get('machine', 'local')}]" for a in agents]
            aidx = select_menu("Change machine for:", names, back_option=True)
            if aidx == -1:
                continue
            midx = select_menu("New machine:", machine_names)
            agents[aidx]["machine"] = machine_names[midx]
            agents[aidx]["cgroup"] = machine_names[midx] == "local"
            _save_toml_from_dict(data, config_path)
            ok(f"Set {agents[aidx]['name']} machine to {machine_names[midx]}")


def _configure_machines(data: dict) -> None:
    """Machine management sub-menu."""
    config_path = _resolve_config_path()
    machines = data.setdefault("machines", [])

    while True:
        print()
        info("Machines:")
        agents = data.get("agents", [])
        agent_counts: dict[str, int] = {}
        for a in agents:
            m = a.get("machine", "local")
            agent_counts[m] = agent_counts.get(m, 0) + 1

        print(f"    {'local':<20} {'(this machine)':<25} {agent_counts.get('local', 0)} agents")
        for m in machines:
            name = m.get("name", "?")
            ssh = m.get("ssh", "?")
            print(f"    {name:<20} {ssh:<25} {agent_counts.get(name, 0)} agents")
        print()

        choice = select_menu(
            "What to do?",
            ["Add machine", "Remove machine", "Test SSH connectivity"],
            back_option=True,
        )

        if choice == -1:
            return
        elif choice == 0:
            name = text_input("Machine name (e.g. worker-1)")
            ssh_target = text_input(f"SSH target for '{name}' (user@host)")
            if confirm("Test SSH?", default=True):
                print(f"    Testing {ssh_target}...", end=" ", flush=True)
                if test_ssh(ssh_target):
                    print(f"{GREEN}Connected{NC}")
                else:
                    print(f"{RED}Failed{NC}")
            machines.append({"name": name, "ssh": ssh_target})
            _save_toml_from_dict(data, config_path)
            ok(f"Added machine '{name}'")

        elif choice == 1:
            if not machines:
                warn("No remote machines to remove.")
                continue
            names = [m.get("name", "?") for m in machines]
            ridx = select_menu("Remove which machine?", names, back_option=True)
            if ridx == -1:
                continue
            removed = names[ridx]
            data["machines"] = [m for m in machines if m.get("name") != removed]
            machines = data["machines"]
            _save_toml_from_dict(data, config_path)
            ok(f"Removed machine '{removed}'")

        elif choice == 2:
            for m in machines:
                name = m.get("name", "?")
                ssh = m.get("ssh", "?")
                print(f"    Testing {name} ({ssh})...", end=" ", flush=True)
                if test_ssh(ssh):
                    print(f"{GREEN}OK{NC}")
                else:
                    print(f"{RED}FAIL{NC}")


def _configure_rules(data: dict) -> None:
    """Edit team rules."""
    config_path = _resolve_config_path()
    team = data.setdefault("team", {})

    section_header("Team Rules")
    team["name"] = text_input("Team name", default=team.get("name", "my-team"))
    team["boot_prompt"] = text_input("Boot prompt", default=team.get("boot_prompt", "Run your daily routine."))
    team["stagger_seconds"] = number_input("Stagger delay (seconds)", default=team.get("stagger_seconds", 10), min_val=0, max_val=120)

    policies = data.setdefault("policies", {})
    policies["guardian"] = confirm("Enable guardian watchdog?", default=policies.get("guardian", True))
    policies["courier"] = confirm("Enable courier messaging?", default=policies.get("courier", True))

    _save_toml_from_dict(data, config_path)
    ok("Rules updated")


def _configure_policies(data: dict) -> None:
    """Edit policies."""
    config_path = _resolve_config_path()
    policies = data.setdefault("policies", {})

    section_header("Policies")
    current_perm = policies.get("permission_mode", "bypassPermissions")
    perm_opts = ["bypassPermissions", "default", "acceptEdits"]
    default_idx = perm_opts.index(current_perm) if current_perm in perm_opts else 0
    pidx = select_menu("Permission mode:", perm_opts, default=default_idx)
    policies["permission_mode"] = perm_opts[pidx]

    policies["agent_memory"] = confirm("Enable agent memory?", default=policies.get("agent_memory", True))

    comm_opts = ["full", "basic", "none"]
    current_comm = policies.get("communication", "full")
    cidx_default = comm_opts.index(current_comm) if current_comm in comm_opts else 0
    cidx = select_menu("Communication protocol:", comm_opts, default=cidx_default)
    policies["communication"] = comm_opts[cidx]

    _save_toml_from_dict(data, config_path)
    ok("Policies updated")


def _view_config(data: dict) -> None:
    """Display current configuration."""
    config_path = _resolve_config_path()

    section_header("Current Configuration")
    hint(f"File: {config_path}")
    print()

    team = data.get("team", {})
    if team:
        print(f"  {BRIGHT_CYAN}[team]{NC}")
        for k, v in team.items():
            print(f"    {DIM}{k}{NC} = {BOLD}{v}{NC}")
        print()

    policies = data.get("policies", {})
    if policies:
        print(f"  {BRIGHT_CYAN}[policies]{NC}")
        for k, v in policies.items():
            val_color = GREEN if v is True else (RED if v is False else "")
            val_nc = NC if val_color else ""
            print(f"    {DIM}{k}{NC} = {val_color}{v}{val_nc}")
        print()

    agents = data.get("agents", [])
    print(f"  {BRIGHT_CYAN}Agents ({len(agents)}):{NC}")
    for a in agents:
        name = a.get("name", "?")
        model = a.get("model", "sonnet")
        machine = a.get("machine", "local")
        model_color = CYAN if model == "opus" else (GREEN if model == "sonnet" else DIM)
        print(f"    {name:<16} {model_color}{model}{NC}  {DIM}{machine}{NC}")
    print()


# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# RUNNING STATE: SESSION MANAGEMENT
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

def flow_running(data: dict) -> None:
    """State 3: Session is active."""
    team = data.get("team", {})
    team_name = team.get("name", "soul-team")

    while True:
        choice = select_menu(
            "What would you like to do?",
            [
                "Attach to session",
                "Health dashboard",
                "Agent status board",
                "Send message to agent",
                "Restart dead agents",
                "Stop session",
                "Configure (for next launch)",
                "Exit",
            ],
            descriptions=[
                "Open the tmux session",
                "Service status, agent counts, events",
                "Per-agent model, machine, status",
                "Route a message via courier",
                "Revive agents that have exited",
                "Shut down all agents and services",
                "Edit config for next launch",
                "",
            ],
        )

        if choice == 0:
            _attach_session(team_name)
            return
        elif choice == 1:
            _health_dashboard(team_name, data)
        elif choice == 2:
            _agent_status_board(team_name, data)
        elif choice == 3:
            _send_message(team_name, data)
        elif choice == 4:
            _restart_dead_agents(team_name, data)
        elif choice == 5:
            if confirm("Stop the entire session?", default=False):
                _stop_session(team_name)
                return
        elif choice == 6:
            _configure_menu(data)
        elif choice == 7:
            print()
            hint("Session still running. Run 'soul-team' to return.")
            return


def _attach_session(team_name: str) -> None:
    """Attach to the running tmux session."""
    print(f"  Attaching to {team_name}...")
    os.execvp("tmux", ["tmux", "attach-session", "-t", team_name])


def _health_dashboard(team_name: str, data: dict) -> None:
    """Show health dashboard (refreshable)."""
    while True:
        # Gather health data
        alive, total = _count_running_agents(team_name)

        # Check services
        services = _check_services()

        # Memory estimate from heartbeat files
        heartbeat_dir = HOME / ".clawteam" / "heartbeat"
        memory_files = list(heartbeat_dir.glob("*.json")) if heartbeat_dir.exists() else []

        # Event files
        event_dir = HOME / ".clawteam" / "teams" / team_name / "queue"
        event_count = len(list(event_dir.glob("*.json"))) if event_dir.exists() else 0

        # Uptime
        uptime = _get_session_uptime(team_name)

        print()
        w = 52
        print(f"  {GRAY}{BOX_TL}{BOX_H * w}{BOX_TR}{NC}")
        print(f"  {GRAY}{BOX_V}{NC} {BOLD}Health Dashboard{NC}{' ' * (w - 17)}{GRAY}{BOX_V}{NC}")
        print(f"  {GRAY}{BOX_V}{NC}{' ' * w}{GRAY}{BOX_V}{NC}")

        # Services row
        svc_str = "  ".join(status_dot(name, is_ok) for name, is_ok in services.items())
        svc_label = f" {BOLD}Services{NC}   {svc_str}"
        # Approximate visible length (strip ANSI for padding)
        print(f"  {GRAY}{BOX_V}{NC}{svc_label}{' ' * 2}{GRAY}{BOX_V}{NC}")

        # Agents row
        agent_color = GREEN if alive == total else (YELLOW if alive > 0 else RED)
        down = total - alive
        down_str = f", {RED}{down} down{NC}" if down > 0 else ""
        print(f"  {GRAY}{BOX_V}{NC}  {BOLD}Agents{NC}     {agent_color}{alive} running{NC}{down_str}, {total} total{' ' * 6}{GRAY}{BOX_V}{NC}")

        # Events row
        print(f"  {GRAY}{BOX_V}{NC}  {BOLD}Events{NC}     {event_count} queued{' ' * (w - 21)}{GRAY}{BOX_V}{NC}")

        # Uptime row
        print(f"  {GRAY}{BOX_V}{NC}  {BOLD}Uptime{NC}     {uptime}{' ' * max(1, w - 12 - len(uptime))}{GRAY}{BOX_V}{NC}")

        print(f"  {GRAY}{BOX_V}{NC}{' ' * w}{GRAY}{BOX_V}{NC}")
        print(f"  {GRAY}{BOX_BL}{BOX_H * w}{BOX_BR}{NC}")
        print()

        if not _supports_raw_mode():
            input(f"  Press Enter to go back...")
            return

        print(f"  {GRAY}r Refresh  {MIDDOT}  q Back  {MIDDOT}  Ctrl+C Quit{NC}")
        _hide_cursor()
        try:
            key = _read_key()
            if key == "q" or key == "escape":
                _clear_lines(12)
                return
            elif key == "r":
                _clear_lines(12)
                continue
            elif key == "ctrl-c":
                _show_cursor()
                raise KeyboardInterrupt()
            else:
                _clear_lines(12)
        finally:
            _show_cursor()


def _agent_status_board(team_name: str, data: dict) -> None:
    """Show per-agent status with polished table."""
    panes_json = HOME / ".clawteam" / "teams" / team_name / "panes.json"
    if not panes_json.exists():
        warn("No panes.json found. Session may not be tracked.")
        return

    try:
        panes = json.loads(panes_json.read_text())
    except Exception:
        warn("Could not read panes.json")
        return

    agents = data.get("agents", [])
    agent_info = {a.get("name", ""): a for a in agents}

    section_header("Agent Status Board")

    # Column widths
    cw = {"name": 16, "model": 10, "machine": 12, "status": 12}

    print(f"  {BOLD}{'AGENT':<{cw['name']}} {'MODEL':<{cw['model']}} {'MACHINE':<{cw['machine']}} {'STATUS'}{NC}")
    total_w = sum(cw.values())
    print(f"  {GRAY}{BOX_H * total_w}{NC}")

    running_count = 0
    dead_count = 0

    for agent_name, pane_id in panes.items():
        if agent_name == "team-lead":
            continue

        a = agent_info.get(agent_name, {})
        model = a.get("model", "?")
        machine = a.get("machine", "?")

        try:
            result = subprocess.run(
                ["tmux", "capture-pane", "-p", "-t", pane_id, "-S", "-3"],
                capture_output=True, text=True,
            )
            content = result.stdout.strip()
            if content and not re.match(r'^[a-z]+@[a-zA-Z0-9-]+[^>]*\$\s*$', content):
                status_str = f"{GREEN}{DOT} running{NC}"
                running_count += 1
            else:
                status_str = f"{RED}{DOT} down{NC}"
                dead_count += 1
        except Exception:
            status_str = f"{YELLOW}{DOT} unknown{NC}"

        model_color = CYAN if model == "opus" else (GREEN if model == "sonnet" else DIM)
        print(f"  {agent_name:<{cw['name']}} {model_color}{model:<{cw['model']}}{NC} {machine:<{cw['machine']}} {status_str}")

    print(f"  {GRAY}{BOX_H * total_w}{NC}")
    summary_parts = [f"{GREEN}{running_count} running{NC}"]
    if dead_count > 0:
        summary_parts.append(f"{RED}{dead_count} down{NC}")
    print(f"  {', '.join(summary_parts)}")
    print()


def _send_message(team_name: str, data: dict) -> None:
    """Send a message to an agent."""
    agents = data.get("agents", [])
    names = [a.get("name", "?") for a in agents] + ["team-lead"]

    idx = select_menu("Send message to:", names, back_option=True)
    if idx == -1:
        return

    target = names[idx]
    msg = text_input("Message")
    if not msg:
        return

    # Use clawteam CLI
    clawteam = HOME / ".local" / "bin" / "clawteam"
    if clawteam.exists():
        result = subprocess.run(
            [str(clawteam), "inbox", "send", team_name, target, msg, "--from", "team-lead"],
            capture_output=True, text=True,
        )
        if result.returncode == 0:
            ok(f"Message sent to {target}")
        else:
            fail(f"Failed to send: {result.stderr.strip()}")
    else:
        warn("clawteam CLI not found -- message not sent.")


def _restart_dead_agents(team_name: str, data: dict) -> None:
    """Restart agents that have died."""
    panes_json = HOME / ".clawteam" / "teams" / team_name / "panes.json"
    if not panes_json.exists():
        warn("No panes.json found.")
        return

    try:
        panes = json.loads(panes_json.read_text())
    except Exception:
        warn("Could not read panes.json")
        return

    agents = data.get("agents", [])
    agent_info = {a.get("name", ""): a for a in agents}
    dev_agents = {"shuri", "happy"}
    c_cmd = "claude --permission-mode bypassPermissions"

    revived = 0
    for agent_name, pane_id in panes.items():
        if agent_name == "team-lead":
            continue

        try:
            result = subprocess.run(
                ["tmux", "capture-pane", "-p", "-t", pane_id, "-S", "-5"],
                capture_output=True, text=True,
            )
            content = result.stdout.strip()

            if not content or re.match(r'^[a-z]+@[a-zA-Z0-9-]+[^>]*\$\s*$', content):
                a = agent_info.get(agent_name, {})
                model = a.get("model", "sonnet")
                machine = a.get("machine", "local")

                dev_flag = ""
                if agent_name in dev_agents:
                    dev_flag = f"--append-system-prompt-file {HOME}/.claude/CLAUDE-dev.md"

                if machine == "local":
                    launch_cmd = (
                        f"export SOUL_AGENT_NAME={agent_name} SOUL_TEAM_NAME={team_name} && "
                        f"systemd-run --user --slice=soul-agents.slice --scope "
                        f"{c_cmd} --agent {agent_name} {dev_flag}"
                    )
                else:
                    ssh_target = a.get("ssh", "")
                    if not ssh_target:
                        for m in data.get("machines", []):
                            if m.get("name") == machine:
                                ssh_target = m.get("ssh", "")
                                break
                    launch_cmd = (
                        f"ssh -t {ssh_target} "
                        f"'export SOUL_AGENT_NAME={agent_name} SOUL_TEAM_NAME={team_name} && "
                        f"{c_cmd} --agent {agent_name} {dev_flag}'"
                    )

                subprocess.run(["tmux", "send-keys", "-t", pane_id, launch_cmd, "Enter"])
                ok(f"Reviving {agent_name}")
                revived += 1
        except Exception:
            warn(f"Could not check {agent_name}")

    if revived == 0:
        ok("All agents are alive.")
    else:
        ok(f"Revived {revived} agent(s)")


def _stop_session(team_name: str) -> None:
    """Stop the running session."""
    print(f"  Stopping {team_name}...")

    # Kill sidecars
    subprocess.run(["pkill", "-f", "soul-sidecar"], capture_output=True)

    # Stop services
    for svc in ["soul-courier", "soul-router", "soul-guardian"]:
        subprocess.run(["systemctl", "--user", "stop", f"{svc}.service"], capture_output=True)

    # Kill tmux session
    subprocess.run(["tmux", "kill-session", "-t", team_name], capture_output=True)

    ok(f"Session '{team_name}' stopped.")


# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# LAUNCH TEAM (the core bash logic, ported to Python)
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

def _launch_team(data: dict, selected_agents: list[str] | None = None) -> None:
    """Launch the agent team in tmux. This is the main event."""
    team = data.get("team", {})
    agents = data.get("agents", [])
    team_name = team.get("name", "soul-team")
    boot_prompt = team.get("boot_prompt", "Run your daily routine then enter proactive mode when idle.")
    stagger = team.get("stagger_seconds", 10)
    dev_agents = {"shuri", "happy"}
    c_cmd = "claude --permission-mode bypassPermissions"
    clawteam = HOME / ".local" / "bin" / "clawteam"
    panes_json_path = HOME / ".clawteam" / "teams" / team_name / "panes.json"

    # Build agent list
    all_agents = [a.get("name", "") for a in agents]
    agent_machines = {a.get("name", ""): a.get("machine", "local") for a in agents}
    agent_ssh = {}
    for a in agents:
        if a.get("ssh"):
            agent_ssh[a["name"]] = a["ssh"]
        elif a.get("machine", "local") != "local":
            for m in data.get("machines", []):
                if m.get("name") == a.get("machine"):
                    agent_ssh[a["name"]] = m.get("ssh", "")
    agent_models = {a.get("name", ""): a.get("model", "sonnet") for a in agents}

    if selected_agents:
        # Validate
        for a in selected_agents:
            if a not in agent_machines:
                fail(f"Unknown agent '{a}'. Valid: {', '.join(all_agents)}")
                return
        launch_agents = selected_agents
    else:
        launch_agents = all_agents

    if not launch_agents:
        fail("No agents to launch.")
        return

    num = len(launch_agents)
    info(f"Launching {num} agents with {stagger}s stagger...")
    print()

    # ── ClawTeam init ──
    if clawteam.exists():
        subprocess.run([str(clawteam), "team", "spawn-team", team_name], capture_output=True)

    # ── Native inbox dirs ──
    native_inbox = HOME / ".claude" / "teams" / team_name / "inboxes"
    native_inbox.mkdir(parents=True, exist_ok=True)
    for agent_name in all_agents + ["team-lead"]:
        inbox_file = native_inbox / f"{agent_name}.json"
        if not inbox_file.exists():
            inbox_file.write_text("[]")

    # ── ClawTeam comms dirs ──
    for subdir in ["queue", "broadcast", "discussions", "sidecar"]:
        (HOME / ".clawteam" / "teams" / team_name / subdir).mkdir(parents=True, exist_ok=True)
    for agent_name in all_agents + ["team-lead"]:
        (HOME / ".clawteam" / "teams" / team_name / "inboxes" / f"{agent_name}_{agent_name}" / "archive").mkdir(parents=True, exist_ok=True)
    (HOME / ".clawteam" / "heartbeat").mkdir(parents=True, exist_ok=True)

    # ── SSH pre-flight (only if remote agents selected) ──
    needs_remote = any(agent_machines.get(a, "local") != "local" for a in launch_agents)
    if needs_remote:
        pc_ssh = None
        for a in launch_agents:
            if agent_machines.get(a, "local") != "local":
                pc_ssh = agent_ssh.get(a)
                break
        if pc_ssh:
            print(f"  Checking remote mount on {pc_ssh}...")
            subprocess.run(
                ["ssh", pc_ssh, "sudo systemctl start soul-mounts.service 2>/dev/null"],
                capture_output=True,
            )

    # ── Cleanup stale ──
    subprocess.run(["pkill", "-f", "soul-sidecar.sh"], capture_output=True)
    subprocess.run(["pkill", "-f", "soul-sidecar-wrapper.sh"], capture_output=True)
    subprocess.run(["systemctl", "--user", "stop", "soul-courier.service"], capture_output=True)
    subprocess.run(["pkill", "-f", "soul-bridge.py"], capture_output=True)
    subprocess.run(["tmux", "kill-session", "-t", team_name], capture_output=True)

    # Clear sidecar state
    sidecar_dir = HOME / ".clawteam" / "teams" / team_name / "sidecar"
    for f in sidecar_dir.glob("*-seen.log"):
        f.unlink(missing_ok=True)
    for f in sidecar_dir.glob("*-interrupt.lock"):
        f.unlink(missing_ok=True)
    queue_dir = HOME / ".clawteam" / "teams" / team_name / "queue"
    for f in queue_dir.glob("*.json"):
        f.write_text("[]")

    # ── Create tmux layout ──
    cols = 1 if num <= 3 else (2 if num <= 6 else 3)

    subprocess.run(["tmux", "new-session", "-d", "-s", team_name, "-n", "soul"], check=True)
    ceo_pane = subprocess.run(
        ["tmux", "display-message", "-t", team_name, "-p", "#{pane_id}"],
        capture_output=True, text=True,
    ).stdout.strip()

    # Horizontal splits
    h_splits = {1: [75], 2: [75, 50], 3: [75, 66, 50]}
    col_panes = []
    last_pane = ceo_pane
    for c in range(cols):
        subprocess.run(
            ["tmux", "split-window", "-h", "-t", last_pane, "-l", f"{h_splits[cols][c]}%"],
            check=True,
        )
        new_pane = subprocess.run(
            ["tmux", "display-message", "-t", team_name, "-p", "#{pane_id}"],
            capture_output=True, text=True,
        ).stdout.strip()
        col_panes.append(new_pane)
        last_pane = new_pane

    # Round-robin agents to columns
    col_agents: list[list[str]] = [[] for _ in range(cols)]
    for i, agent_name in enumerate(launch_agents):
        col_agents[i % cols].append(agent_name)

    pane_map: dict[str, str] = {}

    for c in range(cols):
        agents_in_col = col_agents[c]
        n_rows = len(agents_in_col)
        row_panes = [col_panes[c]]

        if n_rows == 2:
            subprocess.run(["tmux", "split-window", "-v", "-t", col_panes[c], "-l", "50%"])
            new_pane = subprocess.run(
                ["tmux", "display-message", "-t", team_name, "-p", "#{pane_id}"],
                capture_output=True, text=True,
            ).stdout.strip()
            row_panes.append(new_pane)
        elif n_rows == 3:
            result = subprocess.run(
                ["tmux", "split-window", "-v", "-t", col_panes[c], "-l", "66%", "-P", "-F", "#{pane_id}"],
                capture_output=True, text=True,
            )
            mid = result.stdout.strip()
            subprocess.run(["tmux", "split-window", "-v", "-t", mid, "-l", "50%"])
            bot = subprocess.run(
                ["tmux", "display-message", "-t", team_name, "-p", "#{pane_id}"],
                capture_output=True, text=True,
            ).stdout.strip()
            row_panes.append(mid)
            row_panes.append(bot)

        for r in range(n_rows):
            agent_name = agents_in_col[r]
            pane_map[agent_name] = row_panes[r]
            title = agent_name.capitalize()
            if agent_machines.get(agent_name, "local") != "local":
                title += "*"
            subprocess.run(["tmux", "select-pane", "-t", row_panes[r], "-T", title])

    subprocess.run(["tmux", "select-pane", "-t", ceo_pane, "-T", "CEO"])

    # ── tmux styling ──
    for opt, val in [
        ("pane-border-status", "top"),
        ("pane-border-format", " #{pane_title} "),
        ("pane-active-border-style", "fg=#e8a849"),
        ("pane-border-style", "fg=#444444"),
        ("mouse", "on"),
        ("status", "off"),
    ]:
        subprocess.run(["tmux", "set-option", "-t", team_name, opt, val])

    # ── Write panes.json ──
    panes_data = {"team-lead": ceo_pane}
    panes_data.update(pane_map)
    panes_json_path.parent.mkdir(parents=True, exist_ok=True)
    panes_json_path.write_text(json.dumps(panes_data, indent=2))

    # ── Launch CEO ──
    time.sleep(1)
    subprocess.run([
        "tmux", "send-keys", "-t", ceo_pane,
        f"export SOUL_AGENT_NAME=team-lead SOUL_TEAM_NAME={team_name} && {c_cmd}",
        "Enter",
    ])
    subprocess.run(["tmux", "select-pane", "-t", ceo_pane])

    ok(f"CEO ready. {num} agents launching with {stagger}s stagger...")

    # ── Background: launch agents + services ──
    # Fork a subprocess so we can attach immediately
    pid = os.fork()
    if pid == 0:
        # Child process: launch agents
        try:
            # Run preflight
            preflight = REPO_ROOT / "ops" / "agent-preflight.sh"
            if preflight.exists():
                subprocess.run(["bash", str(preflight), "--all"], capture_output=True)

            time.sleep(3)

            for agent_name in launch_agents:
                pane_id = pane_map[agent_name]
                machine = agent_machines.get(agent_name, "local")
                model = agent_models.get(agent_name, "sonnet")
                dev_flag = ""
                if agent_name in dev_agents:
                    dev_flag = f"--append-system-prompt-file {HOME}/.claude/CLAUDE-dev.md"

                if machine == "local":
                    cmd = (
                        f"export SOUL_AGENT_NAME={agent_name} SOUL_TEAM_NAME={team_name} && "
                        f"systemd-run --user --slice=soul-agents.slice --scope "
                        f"{c_cmd} --agent {agent_name} {dev_flag}"
                    )
                else:
                    ssh_target = agent_ssh.get(agent_name, "")
                    cmd = (
                        f"ssh -t {ssh_target} "
                        f"'export SOUL_AGENT_NAME={agent_name} SOUL_TEAM_NAME={team_name} && "
                        f"{c_cmd} --agent {agent_name} {dev_flag}'"
                    )

                subprocess.run(["tmux", "send-keys", "-t", pane_id, cmd, "Enter"])
                # Wait for trust prompt / TUI
                time.sleep(8)
                subprocess.run(["tmux", "send-keys", "-t", pane_id, "", "Enter"])
                time.sleep(5)

                # Type boot prompt with time context
                time_ctx = _get_soul_time()
                agent_boot = (
                    f"{time_ctx} {boot_prompt} "
                    f"(You are {agent_name}. Your preflight data is at "
                    f"~/.soul/preflight/{agent_name}.txt -- read it instead of running individual checks. "
                    f"Then run: clawteam inbox receive {team_name} --agent {agent_name})"
                )
                subprocess.run(["tmux", "send-keys", "-t", pane_id, agent_boot, "Enter"])
                time.sleep(stagger)

            # Start services
            CLAUDE_LOGS_DIR.mkdir(parents=True, exist_ok=True)
            subprocess.run(["systemctl", "--user", "daemon-reload"], capture_output=True)

            for svc in ["soul-router", "soul-courier", "soul-guardian"]:
                subprocess.run(["systemctl", "--user", "start", f"{svc}.service"], capture_output=True)

            # Heartbeat
            heartbeat = REPO_ROOT / "ops" / "soul-heartbeat.sh"
            if heartbeat.exists():
                log_file = open(CLAUDE_LOGS_DIR / "soul-heartbeat.log", "a")
                subprocess.Popen(["bash", str(heartbeat)], stdout=log_file, stderr=log_file)

            # Time beacon
            beacon = REPO_ROOT / "ops" / "soul-time-beacon.sh"
            if beacon.exists():
                log_file = open(CLAUDE_LOGS_DIR / "soul-time-beacon.log", "a")
                subprocess.Popen(["bash", str(beacon)], stdout=log_file, stderr=log_file)

        except Exception:
            pass
        finally:
            os._exit(0)

    # Parent: attach to tmux
    os.execvp("tmux", ["tmux", "attach-session", "-t", team_name])


def _get_soul_time() -> str:
    """Generate time context string for agent boot prompts."""
    from datetime import datetime
    try:
        # Use IST
        tz_result = subprocess.run(
            ["date", "+%Y-%m-%dT%H:%M:%S+05:30"],
            capture_output=True, text=True, env={**os.environ, "TZ": "Asia/Kolkata"},
        )
        iso_time = tz_result.stdout.strip()
        date_result = subprocess.run(
            ["date", "+%Y-%m-%d %A %H:%M %H %V %u"],
            capture_output=True, text=True, env={**os.environ, "TZ": "Asia/Kolkata"},
        )
        parts = date_result.stdout.strip().split()
        if len(parts) >= 6:
            date_str, day, time_str, hour_str, week, dow = parts[0], parts[1], parts[2], parts[3], parts[4], parts[5]
            hour = int(hour_str)
            mode = "NIGHT"
            if 6 <= hour < 11:
                mode = "MORNING"
            elif 11 <= hour < 17:
                mode = "AFTERNOON"
            elif 17 <= hour < 22:
                mode = "EVENING"
            return (
                f"[SOUL-TIME] datetime: {iso_time} date: {date_str} "
                f"day: {day} time: {time_str} IST mode: {mode} "
                f"week_number: {week} day_of_week: {dow} [/SOUL-TIME]"
            )
    except Exception:
        pass
    return f"[SOUL-TIME] datetime: {datetime.now().isoformat()} [/SOUL-TIME]"


# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# DRY RUN
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

def _dry_run(data: dict, selected_agents: list[str] | None = None) -> None:
    """Validate configuration without launching."""
    agents = data.get("agents", [])
    config_path = _resolve_config_path()

    if selected_agents:
        all_names = {a.get("name", "") for a in agents}
        for s in selected_agents:
            if s not in all_names:
                fail(f"Unknown agent '{s}'. Valid: {', '.join(sorted(all_names))}")
                return
        display_agents = [a for a in agents if a.get("name") in selected_agents]
    else:
        display_agents = agents

    print()
    info("DRY RUN: Config Validation")
    print()

    # Roster
    info("Agent Roster:")
    print(f"  {BOLD}{'NAME':<16} {'MODEL':<10} {'MACHINE':<12}{NC}")
    print(f"  {GRAY}{'─' * 15} {'─' * 9} {'─' * 11}{NC}")
    for a in display_agents:
        print(f"  {a.get('name', '?'):<16} {a.get('model', 'sonnet'):<10} {a.get('machine', 'local'):<12}")
    print()

    # File checks
    errors = 0
    info("File Checks:")
    checks = [
        ("TOML config", config_path),
        ("CLAUDE.md (global)", HOME / ".claude" / "CLAUDE.md"),
        ("CLAUDE-dev.md", HOME / ".claude" / "CLAUDE-dev.md"),
        ("clawteam CLI", HOME / ".local" / "bin" / "clawteam"),
    ]
    for label, path in checks:
        if path.exists():
            print(f"  {GREEN}[OK]{NC}   {label}: {path}")
        else:
            print(f"  {RED}[FAIL]{NC} {label}: {path}")
            errors += 1

    for a in display_agents:
        role_file = HOME / ".claude" / "agents" / f"{a.get('name', '')}.md"
        if role_file.exists():
            print(f"  {GREEN}[OK]{NC}   Agent role: {role_file}")
        else:
            print(f"  {YELLOW}[WARN]{NC} Agent role: {role_file} (not found)")
    print()

    # Services
    info("Service Units:")
    for svc in ["soul-guardian", "soul-courier", "soul-router"]:
        unit = HOME / ".config" / "systemd" / "user" / f"{svc}.service"
        if unit.exists():
            print(f"  {GREEN}[OK]{NC}   {svc}.service")
        else:
            print(f"  {YELLOW}[WARN]{NC} {svc}.service (not found at {unit})")
    print()

    # Summary
    local_count = sum(1 for a in display_agents if a.get("machine", "local") == "local")
    remote_count = len(display_agents) - local_count
    info("Summary:")
    print(f"  Total agents: {len(display_agents)} (local: {local_count}, remote: {remote_count})")
    stagger = data.get("team", {}).get("stagger_seconds", 10)
    boot = data.get("team", {}).get("boot_prompt", "")
    print(f"  Stagger delay: {stagger}s")
    print(f"  Boot prompt: {boot[:60]}...")
    print()

    if errors > 0:
        fail(f"{errors} required file(s) missing. Fix before launching.")
    else:
        ok("All checks passed. Safe to launch.")


# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# CONTINUE MODE
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

def _continue_session(data: dict) -> None:
    """Reattach + heal + revive dead agents."""
    team_name = data.get("team", {}).get("name", "soul-team")

    if subprocess.run(["tmux", "has-session", "-t", team_name], capture_output=True).returncode != 0:
        fail(f"No {team_name} session found. Run 'soul-team' to start fresh.")
        sys.exit(1)

    print(f"  Continuing {team_name} session...")

    # Heal services
    subprocess.run(["systemctl", "--user", "restart", "soul-courier.service"], capture_output=True)

    # Check router
    router_running = subprocess.run(["pgrep", "-f", "soul-router.py"], capture_output=True).returncode == 0
    if not router_running:
        router_script = REPO_ROOT / "router" / "router.py"
        if router_script.exists():
            CLAUDE_LOGS_DIR.mkdir(parents=True, exist_ok=True)
            log_file = open(CLAUDE_LOGS_DIR / "soul-router.log", "a")
            subprocess.Popen(["python3", str(router_script)], stdout=log_file, stderr=log_file)
            ok("Router restarted")

    # Revive dead agents
    _restart_dead_agents(team_name, data)

    # Attach
    os.execvp("tmux", ["tmux", "attach-session", "-t", team_name])


# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# MANAGEMENT SUBCOMMANDS (backward compat, called from menus or CLI)
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

def cmd_add_agent(args) -> None:
    """Add an agent from a template or interactively."""
    config_path = _resolve_config_path()
    if not config_path.exists():
        fail(f"No config found at {config_path}. Run 'soul-team' first.")
        sys.exit(1)

    data = _load_toml(config_path)
    agents = data.setdefault("agents", [])
    existing_names = {a["name"] for a in agents}

    if args.custom:
        name = text_input("Agent name")
        if name in existing_names:
            fail(f"Agent '{name}' already exists.")
            sys.exit(1)
        role = text_input("Agent role (one-line description)")

        # Model selection
        midx = select_menu("Model:", [
            "opus (most capable, highest cost)",
            "sonnet (balanced capability and speed)",
            "haiku (fastest, lowest cost)",
        ], default=1)
        model = MODEL_OPTIONS[midx]

        machine = text_input("Machine", default="local")
        template_name = None
        if confirm("Base on a template?", default=True):
            tidx = select_menu(
                "Which template?",
                [f"{t} -- {TEMPLATE_DESCRIPTIONS[t]}" for t in AVAILABLE_TEMPLATES],
            )
            template_name = AVAILABLE_TEMPLATES[tidx]

        agent_entry = {"name": name, "model": model, "machine": machine, "cgroup": machine == "local"}
        if template_name:
            agent_entry["template"] = template_name
    else:
        template_name = args.template
        if template_name not in AVAILABLE_TEMPLATES:
            available = ", ".join(AVAILABLE_TEMPLATES)
            fail(f"Unknown template '{template_name}'. Available: {available}")
            sys.exit(1)

        base_name = template_name
        name = base_name
        suffix = 1
        while name in existing_names:
            suffix += 1
            name = f"{base_name}-{suffix}"

        model = _get_template_model_default(template_name)
        agent_entry = {
            "name": name, "model": model, "machine": "local",
            "cgroup": True, "template": template_name,
        }

    agents.append(agent_entry)
    _recalculate_layout(data)
    _save_toml_from_dict(data, config_path)

    # Generate agent .md
    agent_obj = Agent(
        name=agent_entry["name"],
        role=TEMPLATE_DESCRIPTIONS.get(agent_entry.get("template", ""), "custom agent"),
        model=agent_entry["model"], machine=agent_entry["machine"],
        template=agent_entry.get("template"),
    )
    CLAUDE_AGENTS_DIR.mkdir(parents=True, exist_ok=True)
    agent_md_path = CLAUDE_AGENTS_DIR / f"{agent_entry['name']}.md"
    agent_md_path.write_text(generate_agent_md(agent_obj))

    ok(f"Added '{agent_entry['name']}' (model={agent_entry['model']}, machine={agent_entry['machine']})")


def cmd_remove_agent(args) -> None:
    """Remove an agent by name."""
    config_path = _resolve_config_path()
    if not config_path.exists():
        fail(f"No config found at {config_path}. Run 'soul-team' first.")
        sys.exit(1)

    data = _load_toml(config_path)
    agents = data.get("agents", [])
    agent_names = [a["name"] for a in agents]

    name = args.name
    if name not in agent_names:
        fail(f"Agent '{name}' not found. Current: {', '.join(agent_names)}")
        sys.exit(1)

    data["agents"] = [a for a in agents if a["name"] != name]
    _recalculate_layout(data)
    _save_toml_from_dict(data, config_path)

    agent_md = CLAUDE_AGENTS_DIR / f"{name}.md"
    if agent_md.exists():
        agent_md.unlink()
        ok(f"Removed agent persona: {agent_md}")

    ok(f"Removed '{name}' from config.")


def cmd_add_machine(args) -> None:
    """Add a remote machine."""
    config_path = _resolve_config_path()
    if not config_path.exists():
        fail(f"No config found. Run 'soul-team' first.")
        sys.exit(1)

    data = _load_toml(config_path)
    machines = data.setdefault("machines", [])
    existing_names = {m["name"] for m in machines}

    if args.name in existing_names:
        fail(f"Machine '{args.name}' already exists.")
        sys.exit(1)

    if not args.no_test:
        print(f"  Testing SSH to {args.ssh}...", end=" ", flush=True)
        if test_ssh(args.ssh):
            print(f"{GREEN}Connected{NC}")
        else:
            print(f"{RED}Failed{NC}")
            warn("SSH test failed. Machine added anyway.")

    machines.append({"name": args.name, "ssh": args.ssh})
    _save_toml_from_dict(data, config_path)
    ok(f"Added machine '{args.name}' (ssh={args.ssh})")


def cmd_list_agents(args) -> None:
    """List current agent roster."""
    config_path = _resolve_config_path()
    if not config_path.exists():
        fail(f"No config found. Run 'soul-team' first.")
        sys.exit(1)

    data = _load_toml(config_path)
    agents = data.get("agents", [])

    if not agents:
        print("  No agents configured.")
        return

    team_name = data.get("team", {}).get("name", "unnamed")
    print(f"\n  {BOLD}Team: {team_name} ({len(agents)} agents){NC}\n")
    print(f"    {'NAME':<20} {'MODEL':<10} {'MACHINE':<15} {'TEMPLATE'}")
    print(f"    {'─' * 19} {'─' * 9} {'─' * 14} {'─' * 12}")
    for a in agents:
        tmpl = a.get("template", "-")
        print(f"    {a['name']:<20} {a.get('model', 'sonnet'):<10} {a.get('machine', 'local'):<15} {tmpl}")
    print()


def cmd_list_machines(args) -> None:
    """List configured machines."""
    config_path = _resolve_config_path()
    if not config_path.exists():
        fail(f"No config found. Run 'soul-team' first.")
        sys.exit(1)

    data = _load_toml(config_path)
    machines = data.get("machines", [])
    agents = data.get("agents", [])
    agent_counts: dict[str, int] = {}
    for a in agents:
        m = a.get("machine", "local")
        agent_counts[m] = agent_counts.get(m, 0) + 1

    print(f"\n  {BOLD}Machines:{NC}\n")
    print(f"    {'NAME':<20} {'SSH TARGET':<30} {'AGENTS'}")
    print(f"    {'─' * 19} {'─' * 29} {'─' * 6}")
    print(f"    {'local':<20} {'(this machine)':<30} {agent_counts.get('local', 0)}")
    for m in machines:
        name = m.get("name", "?")
        ssh = m.get("ssh", "?")
        print(f"    {name:<20} {ssh:<30} {agent_counts.get(name, 0)}")
    print()


def cmd_config(args) -> None:
    """View or modify config settings."""
    config_path = _resolve_config_path()
    if not config_path.exists():
        fail(f"No config found. Run 'soul-team' first.")
        sys.exit(1)

    data = _load_toml(config_path)

    if args.set_value:
        key, _, value = args.set_value.partition("=")
        key = key.strip()
        value = value.strip()

        if not value:
            fail("Invalid format. Use: --set key=value")
            sys.exit(1)

        team_keys = {"name", "description", "boot_prompt", "stagger_seconds"}
        policy_keys = {"permission_mode", "agent_memory", "communication", "guardian",
                       "courier", "idle_shutdown", "idle_timeout_minutes"}

        if key in team_keys:
            section_name = "team"
        elif key in policy_keys:
            section_name = "policies"
        else:
            fail(f"Unknown key '{key}'. Valid: {', '.join(sorted(team_keys | policy_keys))}")
            sys.exit(1)

        section_data = data.setdefault(section_name, {})

        if value.lower() in ("true", "false"):
            typed_value = value.lower() == "true"
        elif value.isdigit():
            typed_value = int(value)
        else:
            typed_value = value

        old_value = section_data.get(key, "(unset)")
        section_data[key] = typed_value
        _save_toml_from_dict(data, config_path)
        ok(f"Set [{section_name}] {key} = {typed_value} (was: {old_value})")
    else:
        _view_config(data)


# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# QUICK STATUS (non-interactive)
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

def _quick_status() -> None:
    """Non-interactive status output."""
    state, data = detect_state()

    if state == "first_run":
        print(f"  {DIAMOND} soul-team v{VERSION}")
        print(f"  Status: {DIM}not configured{NC}")
        hint("Run 'soul-team' to set up.")
        return

    team_name = data.get("team", {}).get("name", "soul-team")
    agents = data.get("agents", [])

    print(f"  {BRIGHT_CYAN}{DIAMOND_FILL}{NC} {BOLD}soul-team{NC} {DIM}v{VERSION}{NC}")

    if state == "running":
        alive, total = _count_running_agents(team_name)
        uptime = _get_session_uptime(team_name)
        agent_color = GREEN if alive == total else (YELLOW if alive > 0 else RED)
        services = _check_services()
        svc_str = "  ".join(status_dot(name, is_ok) for name, is_ok in services.items())
        print(f"  Team: {team_name}  {MIDDOT}  {agent_color}{alive}/{total} running{NC}  {MIDDOT}  Uptime: {uptime}")
        print(f"  {svc_str}")
    else:
        print(f"  Team: {team_name}  {MIDDOT}  {len(agents)} agents configured  {MIDDOT}  {DIM}Session: stopped{NC}")


# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# MAIN: CLI ARGUMENT PARSING + STATE ROUTER
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

def handle_sigint(signum: int, frame) -> None:
    _show_cursor()
    print(f"\n\n  {YELLOW}Cancelled.{NC}\n")
    sys.exit(130)


def main() -> None:
    signal.signal(signal.SIGINT, handle_sigint)

    parser = argparse.ArgumentParser(
        description="soul-team -- Multi-Agent Runtime for Claude Code",
        formatter_class=argparse.RawDescriptionHelpFormatter,
        epilog=textwrap.dedent("""\
            Just run 'soul-team' with no arguments for interactive mode.
            The CLI detects state automatically and shows the right interface.
        """),
    )

    # Display flags
    parser.add_argument("--version", "-V", action="store_true", help="Show version and exit")
    parser.add_argument("--no-color", action="store_true", help="Disable colored output")

    # Power-user flags (backward compat)
    parser.add_argument("--dry-run", action="store_true", help="Validate config without launching")
    parser.add_argument("--agents", type=str, default=None, help="Comma-separated list of agents to launch")
    parser.add_argument("--continue", dest="cont", action="store_true", help="Reattach + heal + revive dead agents")
    parser.add_argument("--all", action="store_true", help="Launch all agents (explicit)")
    parser.add_argument("--status", action="store_true", help="Quick status check (non-interactive)")
    parser.add_argument("--quick", action="store_true", help="Quick setup (3 agents, no prompts)")
    parser.add_argument("-n", "--num-agents", type=int, default=3, help="Number of agents for --quick")

    # Hidden subcommands for backward compat
    subparsers = parser.add_subparsers(dest="command")

    # init
    init_parser = subparsers.add_parser("init", help="Setup wizard")
    init_parser.add_argument("--quick", action="store_true", dest="init_quick")
    init_parser.add_argument("-n", "--num-agents", type=int, default=3, dest="init_num")

    # add-agent
    add_agent_p = subparsers.add_parser("add-agent", help="Add agent")
    add_agent_p.add_argument("template", nargs="?", default=None)
    add_agent_p.add_argument("--custom", action="store_true")

    # remove-agent
    remove_agent_p = subparsers.add_parser("remove-agent", help="Remove agent")
    remove_agent_p.add_argument("name")

    # add-machine
    add_machine_p = subparsers.add_parser("add-machine", help="Add machine")
    add_machine_p.add_argument("name")
    add_machine_p.add_argument("ssh")
    add_machine_p.add_argument("--no-test", action="store_true")

    # list-agents, list-machines, config
    subparsers.add_parser("list-agents")
    subparsers.add_parser("list-machines")
    config_p = subparsers.add_parser("config")
    config_p.add_argument("--set", dest="set_value")

    args = parser.parse_args()

    # ── Handle --no-color early (before any output) ──
    if args.no_color:
        _disable_colors()

    # ── Handle --version ──
    if args.version:
        print(f"soul-team v{VERSION}")
        print(f"Multi-Agent Runtime for Claude Code")
        print(f"{_TEMPLATE_COUNT} templates  {MIDDOT}  {_LICENSE} License")
        print(f"Python {sys.version.split()[0]}  {MIDDOT}  {sys.platform}")
        return

    # ── Dispatch subcommands (backward compat) ──
    if args.command == "init":
        banner("first_run")
        quick = getattr(args, "init_quick", False)
        num = getattr(args, "init_num", 3)
        should_launch = flow_first_run(quick=quick, num_agents=num)
        if should_launch:
            state, data = detect_state()
            if data:
                _launch_team(data)
        return
    if args.command == "add-agent":
        if not args.template and not args.custom:
            args.custom = True
        cmd_add_agent(args)
        return
    if args.command == "remove-agent":
        cmd_remove_agent(args)
        return
    if args.command == "add-machine":
        cmd_add_machine(args)
        return
    if args.command == "list-agents":
        cmd_list_agents(args)
        return
    if args.command == "list-machines":
        cmd_list_machines(args)
        return
    if args.command == "config":
        cmd_config(args)
        return

    # ── Quick status (non-interactive) ──
    if args.status:
        _quick_status()
        return

    # ── Detect state and route ──
    state, data = detect_state()

    # ── Power-user flags override interactive mode ──
    selected_agents = None
    if args.agents:
        selected_agents = [a.strip() for a in args.agents.split(",")]

    if args.quick:
        banner("first_run")
        should_launch = flow_first_run(quick=True, num_agents=args.num_agents)
        if should_launch:
            state, data = detect_state()
            if data:
                _launch_team(data)
        return

    if args.cont:
        if data is None:
            fail("No config found. Run 'soul-team' to set up first.")
            sys.exit(1)
        _continue_session(data)
        return

    if args.dry_run:
        if data is None:
            fail("No config found. Run 'soul-team' to set up first.")
            sys.exit(1)
        _dry_run(data, selected_agents)
        return

    if selected_agents:
        if data is None:
            fail("No config found. Run 'soul-team' to set up first.")
            sys.exit(1)
        _launch_team(data, selected_agents)
        return

    # ── Interactive mode: state-driven routing ──
    banner(state, data)

    if state == "first_run":
        should_launch = flow_first_run()
        if should_launch:
            state, data = detect_state()
            if data:
                _launch_team(data)

    elif state == "configured":
        flow_configured(data)

    elif state == "running":
        flow_running(data)


if __name__ == "__main__":
    main()
