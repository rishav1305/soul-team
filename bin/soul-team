#!/usr/bin/env python3
"""
soul-team -- One command to rule them all.

Interactive CLI for managing multi-agent Claude Code teams.
Detects state automatically: first run -> setup wizard, configured -> launch,
session running -> management dashboard.

Usage:
    soul-team                         # Interactive mode (auto-detects state)
    soul-team --dry-run               # Validate config without launching
    soul-team --agents happy,shuri    # Launch specific agents only
    soul-team --continue              # Reattach + heal + revive dead agents
    soul-team --status                # Quick status check (non-interactive)

Stdlib only -- no external dependencies.
"""

from __future__ import annotations

import argparse
import json
import os
import re
import shutil
import signal
import subprocess
import sys
import textwrap
import time
from dataclasses import dataclass, field
from datetime import datetime, timezone
from pathlib import Path
from typing import Optional

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# ANSI ESCAPE CODES
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

# Detect NO_COLOR (https://no-color.org/) — can be overridden by --no-color flag
_NO_COLOR = bool(os.environ.get("NO_COLOR")) or not sys.stdout.isatty()

def _c(code: str) -> str:
    """Return ANSI code if color is enabled, empty string otherwise."""
    return "" if _NO_COLOR else code

BOLD = _c("\033[1m")
DIM = _c("\033[2m")
ITALIC = _c("\033[3m")
UNDERLINE = _c("\033[4m")
GREEN = _c("\033[0;32m")
BRIGHT_GREEN = _c("\033[1;32m")
YELLOW = _c("\033[1;33m")
RED = _c("\033[0;31m")
CYAN = _c("\033[0;36m")
BRIGHT_CYAN = _c("\033[1;36m")
MAGENTA = _c("\033[0;35m")
BLUE = _c("\033[0;34m")
BRIGHT_BLUE = _c("\033[1;34m")
WHITE = _c("\033[1;37m")
GRAY = _c("\033[0;90m")
NC = _c("\033[0m")  # No Color / Reset

# Box-drawing characters
BOX_TL = "\u256d"  # top-left
BOX_TR = "\u256e"  # top-right
BOX_BL = "\u2570"  # bottom-left
BOX_BR = "\u256f"  # bottom-right
BOX_H = "\u2500"   # horizontal
BOX_V = "\u2502"   # vertical
BOX_T = "\u252c"   # T-junction top
BOX_CROSS = "\u253c"  # cross junction
BOX_L = "\u251c"   # left T
BOX_R = "\u2524"   # right T
BOX_BT = "\u2534"  # bottom T
BULLET = "\u2022"  # bullet
CHECK = "\u2713"   # checkmark
CROSS = "\u2717"   # cross
ARROW = "\u276f"   # arrow
DOT = "\u25cf"     # filled circle
CIRCLE = "\u25cb"  # empty circle
DIAMOND = "\u25c7"  # diamond (like Claude Code)
DIAMOND_FILL = "\u25c6"  # filled diamond
MIDDOT = "\u00b7"  # middle dot separator

VERSION = "2.0.0"
_TEMPLATE_COUNT = 16
_LICENSE = "MIT"


def _disable_colors() -> None:
    """Disable all ANSI color codes globally (called when --no-color is used)."""
    global _NO_COLOR, BOLD, DIM, ITALIC, UNDERLINE, GREEN, BRIGHT_GREEN, YELLOW, RED
    global CYAN, BRIGHT_CYAN, MAGENTA, BLUE, BRIGHT_BLUE, WHITE, GRAY, NC
    _NO_COLOR = True
    BOLD = DIM = ITALIC = UNDERLINE = ""
    GREEN = BRIGHT_GREEN = YELLOW = RED = ""
    CYAN = BRIGHT_CYAN = MAGENTA = BLUE = BRIGHT_BLUE = ""
    WHITE = GRAY = NC = ""

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# PATHS
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

SCRIPT_DIR = Path(__file__).resolve().parent
REPO_ROOT = SCRIPT_DIR.parent
TEMPLATES_DIR = REPO_ROOT / "agents" / "templates"
PROTOCOL_SRC = REPO_ROOT / "protocols" / "team-protocol-v2.md"
SYSTEMD_SRC = REPO_ROOT / "systemd"

HOME = Path.home()
USER_CONFIG_DIR = HOME / ".soul-team"
CLAUDE_CONFIG_DIR = HOME / ".claude" / "config"
CLAUDE_AGENTS_DIR = HOME / ".claude" / "agents"
CLAUDE_LOGS_DIR = HOME / ".claude" / "logs"

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# INTERACTIVE MENU SYSTEM (stdlib only: termios + ANSI)
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

def _supports_raw_mode() -> bool:
    """Check if the terminal supports raw mode input."""
    try:
        import termios  # noqa: F401
        return sys.stdin.isatty()
    except ImportError:
        return False


def _read_key() -> str:
    """Read a single keypress in raw mode. Returns key identifier string."""
    import termios
    import tty

    fd = sys.stdin.fileno()
    old_settings = termios.tcgetattr(fd)
    try:
        tty.setraw(fd)
        ch = sys.stdin.read(1)

        if ch == "\x1b":
            # Escape sequence
            seq = sys.stdin.read(1)
            if seq == "[":
                code = sys.stdin.read(1)
                if code == "A":
                    return "up"
                elif code == "B":
                    return "down"
                elif code == "C":
                    return "right"
                elif code == "D":
                    return "left"
            return "escape"
        elif ch in ("\r", "\n"):
            return "enter"
        elif ch == "\x03":
            return "ctrl-c"
        elif ch == "\x04":
            return "ctrl-d"
        elif ch == "\x7f" or ch == "\x08":
            return "backspace"
        elif ch == "q" or ch == "Q":
            return "q"
        elif ch == "r" or ch == "R":
            return "r"
        else:
            return ch
    finally:
        termios.tcsetattr(fd, termios.TCSADRAIN, old_settings)


def _clear_lines(n: int) -> None:
    """Move cursor up n lines and clear them."""
    for _ in range(n):
        sys.stdout.write("\033[A")  # Move up
        sys.stdout.write("\033[2K")  # Clear line
    sys.stdout.flush()


def _hide_cursor() -> None:
    sys.stdout.write("\033[?25l")
    sys.stdout.flush()


def _show_cursor() -> None:
    sys.stdout.write("\033[?25h")
    sys.stdout.flush()


def select_menu(title: str, options: list[str], descriptions: list[str] | None = None,
                default: int = 0, back_option: bool = False) -> int:
    """Arrow-key navigable menu. Returns selected index, or -1 for back.

    Falls back to numbered-list selection if raw mode not available.
    If back_option is True, adds a back option that returns -1.
    """
    display_options = list(options)
    display_descs = list(descriptions) if descriptions else None
    if back_option:
        display_options.append(f"{ARROW} Back")
        if display_descs is not None:
            display_descs.append("")

    if not _supports_raw_mode():
        return _select_menu_fallback(title, display_options, display_descs, default, back_option)

    cursor = default
    num_opts = len(display_options)

    # Build navigation hint string
    nav_parts = [f"\u2191/\u2193 Navigate", "Enter Select"]
    if back_option:
        nav_parts.append("Esc Back")
    nav_parts.append("Ctrl+C Quit")
    nav_str = f"  {GRAY}{f'  {MIDDOT}  '.join(nav_parts)}{NC}"

    _hide_cursor()
    try:
        while True:
            # Render
            lines = []
            lines.append(f"  {BRIGHT_BLUE}?{NC} {BOLD}{title}{NC}")
            for i, opt in enumerate(display_options):
                if i == cursor:
                    prefix = f"  {CYAN}\u276f{NC} "
                    line = f"{prefix}{BOLD}{WHITE}{opt}{NC}"
                else:
                    line = f"    {DIM}{opt}{NC}"

                if display_descs and i < len(display_descs or []) and display_descs[i]:
                    sep = f" {GRAY}{MIDDOT}{NC} " if i == cursor else "  "
                    line += f"{sep}{GRAY}{display_descs[i]}{NC}"

                lines.append(line)

            # Navigation hints at bottom
            lines.append("")
            lines.append(nav_str)

            output = "\n".join(lines)
            sys.stdout.write(output + "\n")
            sys.stdout.flush()

            key = _read_key()

            # Clear rendered lines
            _clear_lines(len(lines))

            if key == "up":
                cursor = (cursor - 1) % num_opts
            elif key == "down":
                cursor = (cursor + 1) % num_opts
            elif key == "enter":
                # Show final selection
                selected_text = display_options[cursor]
                sys.stdout.write(f"  {GREEN}{CHECK}{NC} {title} {BOLD}{selected_text}{NC}\n")
                sys.stdout.flush()
                if back_option and cursor == num_opts - 1:
                    return -1
                return cursor
            elif key == "ctrl-c":
                _show_cursor()
                raise KeyboardInterrupt()
            elif key == "escape":
                if back_option:
                    sys.stdout.write(f"  {YELLOW}{ARROW}{NC} {title} {DIM}(back){NC}\n")
                    sys.stdout.flush()
                    return -1
            elif key == "q" and back_option:
                sys.stdout.write(f"  {YELLOW}{ARROW}{NC} {title} {DIM}(back){NC}\n")
                sys.stdout.flush()
                return -1
    finally:
        _show_cursor()


def _select_menu_fallback(title: str, options: list[str], descriptions: list[str] | None,
                          default: int, back_option: bool) -> int:
    """Numbered list fallback when terminal doesn't support raw mode."""
    print(f"  {BOLD}?{NC} {title}")
    for i, opt in enumerate(options):
        marker = f"{GREEN}>{NC}" if i == default else " "
        desc = f"  {GRAY}{descriptions[i]}{NC}" if descriptions and descriptions[i] else ""
        print(f"    {marker} {i + 1}. {opt}{desc}")

    while True:
        raw = input(f"    Choice [{default + 1}]: ").strip()
        if not raw:
            return -1 if (back_option and default == len(options) - 1) else default
        try:
            idx = int(raw) - 1
            if 0 <= idx < len(options):
                if back_option and idx == len(options) - 1:
                    return -1
                return idx
        except ValueError:
            pass
        print(f"    {RED}Enter 1-{len(options)}.{NC}")


def confirm(prompt: str, default: bool = True) -> bool:
    """Y/n confirmation prompt."""
    if _supports_raw_mode():
        hint = f"{'Y' if default else 'y'}/{'n' if default else 'N'}"
        sys.stdout.write(f"  {BRIGHT_BLUE}?{NC} {prompt} {DIM}[{hint}]{NC} ")
        sys.stdout.flush()

        _hide_cursor()
        try:
            while True:
                key = _read_key()
                if key == "enter":
                    result = default
                    break
                elif key in ("y", "Y"):
                    result = True
                    break
                elif key in ("n", "N"):
                    result = False
                    break
                elif key == "ctrl-c":
                    _show_cursor()
                    raise KeyboardInterrupt()
        finally:
            _show_cursor()

        # Clear the prompt line and show result
        sys.stdout.write("\r\033[2K")
        answer = f"{GREEN}Yes{NC}" if result else f"{RED}No{NC}"
        sys.stdout.write(f"  {GREEN}{CHECK}{NC} {prompt} {answer}\n")
        sys.stdout.flush()
        return result

    # Fallback
    hint = "Y/n" if default else "y/N"
    raw = input(f"  {BRIGHT_BLUE}?{NC} {prompt} {DIM}[{hint}]{NC}: ").strip().lower()
    if not raw:
        return default
    return raw in ("y", "yes")


def text_input(prompt: str, default: str = "", allow_empty: bool = False) -> str:
    """Text input with default value."""
    if default:
        display = f"  {BRIGHT_BLUE}?{NC} {prompt} {DIM}({default}){NC}: "
    else:
        display = f"  {BRIGHT_BLUE}?{NC} {prompt}: "

    while True:
        answer = input(display).strip()
        if not answer and default:
            print(f"\033[A\033[2K  {GREEN}{CHECK}{NC} {prompt} {BOLD}{default}{NC}")
            return default
        if answer or allow_empty:
            print(f"\033[A\033[2K  {GREEN}{CHECK}{NC} {prompt} {BOLD}{answer}{NC}")
            return answer
        print(f"    {RED}Please enter a value.{NC}")


def number_input(prompt: str, default: int, min_val: int = 1, max_val: int = 99) -> int:
    """Validated number input."""
    while True:
        raw = text_input(prompt, str(default))
        try:
            val = int(raw)
            if min_val <= val <= max_val:
                return val
            print(f"    {RED}Enter a number between {min_val} and {max_val}.{NC}")
        except ValueError:
            print(f"    {RED}Enter a valid number.{NC}")


def multi_select(title: str, options: list[str], descriptions: list[str] | None = None) -> list[int]:
    """Multi-select with space to toggle, enter to confirm. Returns list of indices."""
    if not _supports_raw_mode():
        return _multi_select_fallback(title, options, descriptions)

    selected = set()
    cursor = 0
    num_opts = len(options)

    _hide_cursor()
    try:
        while True:
            lines = []
            lines.append(f"  {BRIGHT_BLUE}?{NC} {BOLD}{title}{NC} {DIM}(Space toggle  {MIDDOT}  Enter confirm){NC}")
            for i, opt in enumerate(options):
                check = f"{GREEN}{CHECK}{NC}" if i in selected else f"{DIM}{CIRCLE}{NC}"
                if i == cursor:
                    prefix = f"  {CYAN}{ARROW}{NC}"
                else:
                    prefix = "   "

                line = f"{prefix} {check} {opt}"
                if descriptions and descriptions[i]:
                    line += f"  {GRAY}{descriptions[i]}{NC}"
                lines.append(line)

            output = "\n".join(lines)
            sys.stdout.write(output + "\n")
            sys.stdout.flush()

            key = _read_key()
            _clear_lines(len(lines))

            if key == "up":
                cursor = (cursor - 1) % num_opts
            elif key == "down":
                cursor = (cursor + 1) % num_opts
            elif key == " ":
                if cursor in selected:
                    selected.discard(cursor)
                else:
                    selected.add(cursor)
            elif key == "enter":
                chosen = sorted(selected)
                names = ", ".join(options[i] for i in chosen) if chosen else "(none)"
                sys.stdout.write(f"  {GREEN}{CHECK}{NC} {title} {BOLD}{names}{NC}\n")
                sys.stdout.flush()
                return chosen
            elif key == "ctrl-c":
                _show_cursor()
                raise KeyboardInterrupt()
    finally:
        _show_cursor()


def _multi_select_fallback(title: str, options: list[str], descriptions: list[str] | None) -> list[int]:
    """Comma-separated number fallback for multi-select."""
    print(f"  {BOLD}?{NC} {title}")
    for i, opt in enumerate(options):
        desc = f"  {GRAY}{descriptions[i]}{NC}" if descriptions and descriptions[i] else ""
        print(f"    {i + 1}. {opt}{desc}")
    while True:
        raw = input(f"    Select (comma-separated, e.g. 1,3,5): ").strip()
        if not raw:
            return []
        try:
            indices = [int(x.strip()) - 1 for x in raw.split(",")]
            if all(0 <= i < len(options) for i in indices):
                return indices
        except ValueError:
            pass
        print(f"    {RED}Enter valid numbers separated by commas.{NC}")


