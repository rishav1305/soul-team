# UI PRIMITIVES
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

def _get_terminal_width() -> int:
    """Get terminal width, default 80."""
    try:
        return os.get_terminal_size().columns
    except (OSError, ValueError):
        return 80


def banner(state: str = "first_run", data: dict | None = None) -> None:
    """Print the soul-team banner matching Claude Code's style.

    Adapts output based on state: first_run, configured, running.
    """
    print()
    # Primary banner line — clean, minimal, Claude-inspired
    print(f"  {BRIGHT_CYAN}{DIAMOND_FILL}{NC} {BOLD}{WHITE}soul-team{NC} {DIM}v{VERSION}{NC}")
    print(f"  {DIM}Multi-Agent Runtime for Claude Code{NC}")
    print()

    if state == "first_run":
        # Show template count and license
        print(f"  {DIM}{_TEMPLATE_COUNT} agent templates  {MIDDOT}  {_LICENSE} License{NC}")
        print()
        return

    if data is None:
        return

    team = data.get("team", {})
    agents = data.get("agents", [])
    team_name = team.get("name", "unnamed")

    if state == "configured":
        # Count local vs remote
        local = sum(1 for a in agents if a.get("machine", "local") == "local")
        remote = len(agents) - local
        loc_str = f"{local} local"
        if remote > 0:
            loc_str += f", {remote} remote"

        # Model distribution
        models: dict[str, int] = {}
        for a in agents:
            m = a.get("model", "sonnet")
            models[m] = models.get(m, 0) + 1
        model_str = ", ".join(f"{v} {k}" for k, v in sorted(models.items(), key=lambda x: -x[1]))

        print(f"  {BOLD}Team:{NC} {team_name}  {MIDDOT}  {len(agents)} agents  {MIDDOT}  {loc_str}")
        if model_str:
            print(f"  {DIM}Models: {model_str}{NC}")
        print()

    elif state == "running":
        alive, total = _count_running_agents(team_name)
        uptime = _get_session_uptime(team_name)

        # Check services
        services = _check_services()
        svc_str = "  ".join(status_dot(name, is_ok) for name, is_ok in services.items())

        agent_color = GREEN if alive == total else (YELLOW if alive > 0 else RED)
        print(f"  {BOLD}Team:{NC} {team_name}  {MIDDOT}  {agent_color}{alive}/{total} agents running{NC}")
        print(f"  {DIM}Session active since {uptime}{NC}  {MIDDOT}  {svc_str}")
        print()


def _check_services() -> dict[str, bool]:
    """Check systemd service status for guardian, courier, router."""
    services = {}
    for svc in ["soul-guardian", "soul-courier", "soul-router"]:
        try:
            result = subprocess.run(
                ["systemctl", "--user", "is-active", f"{svc}.service"],
                capture_output=True, text=True,
            )
            services[svc.replace("soul-", "").capitalize()] = result.stdout.strip() == "active"
        except Exception:
            services[svc.replace("soul-", "").capitalize()] = False
    return services


def section_header(title: str) -> None:
    """Print a section header with subtle line."""
    print()
    tw = _get_terminal_width()
    line_len = min(tw - 4, 60)
    title_len = len(title) + 2  # space on each side
    right = max(1, line_len - title_len - 3)
    print(f"  {GRAY}{BOX_H * 3} {NC}{DIM}{title}{NC} {GRAY}{BOX_H * right}{NC}")
    print()


def ok(msg: str) -> None:
    print(f"  {GREEN}{CHECK}{NC} {msg}")


def warn(msg: str) -> None:
    print(f"  {YELLOW}!{NC} {msg}")


def fail(msg: str) -> None:
    print(f"  {RED}{CROSS}{NC} {msg}")


def info(msg: str) -> None:
    print(f"  {BRIGHT_BLUE}{DIAMOND}{NC} {msg}")


def status_dot(label: str, ok: bool) -> str:
    """Return a colored status dot with label."""
    dot = f"{GREEN}{DOT}{NC}" if ok else f"{RED}{DOT}{NC}"
    return f"{label}: {dot}"


def hint(text: str) -> None:
    """Print a dim hint/tip line."""
    print(f"  {GRAY}{text}{NC}")


def nav_hints() -> None:
    """Print navigation hints bar at the bottom."""
    parts = [
        f"{DIM}\u2191/\u2193 Navigate{NC}",
        f"{DIM}Enter Select{NC}",
        f"{DIM}q Quit{NC}",
    ]
    print(f"  {f'  {MIDDOT}  '.join(parts)}")
    print()


