#!/bin/bash
# soul-team — Launch the Marvel agent team (v2)
#
# Usage:
#   soul-team                           # Launch all 9 agents (default)
#   soul-team --agents happy,shuri     # Launch only Friday and Shuri
#   soul-team --agents happy           # Launch only Happy
#   soul-team --all                     # Explicit all (same as no flags)
#   soul-team --continue                # Reattach + heal + revive dead agents
#   soul-team --dry-run                 # Validate config without launching
#   soul-team --dry-run --agents happy  # Validate specific agent subset
#
# Layout adapts dynamically to agent count:
#   1-3 agents: CEO + 1 column
#   4-6 agents: CEO + 2 columns
#   7-9 agents: CEO + 3 columns (original layout)
#
# Agents launch in INTERACTIVE mode (TUI) with staggered startup.
# Trust prompt auto-accepted. Boot prompt typed after TUI loads.
#
# Features:
#   - Reads ~/.claude/config/soul-team.toml for agent config
#   - Dynamic tmux layout based on selected agent count
#   - Conditional titan-pc SSH (skipped when only local agents)
#   - Scoped panes.json + sidecars (only selected agents)
#   - Global daemons always start (router, bridge, heartbeat, guardian)

set -euo pipefail

SESSION="soul-team"
PC="rishav@192.168.0.196"
C="claude --permission-mode bypassPermissions"
DEV_AGENTS="shuri happy"  # Agents that load CLAUDE-dev.md (code conventions)
BOOT="Run your daily routine then enter proactive mode when idle."
DELAY=10
CLAWTEAM="$HOME/.local/bin/clawteam"
TOML="$HOME/.claude/config/soul-team.toml"
PANES_JSON="$HOME/.clawteam/teams/soul-team/panes.json"

# ── Parse TOML via single helper (parse_toml.py + jq) ─────────────────────
PARSE_TOML="$HOME/.claude/scripts/parse_toml.py"
if [ -f "$TOML" ] && [ -f "$PARSE_TOML" ]; then
    TOML_JSON=$(python3 "$PARSE_TOML" "$TOML" 2>/dev/null)
    if [ -n "$TOML_JSON" ]; then
        TOML_BOOT=$(echo "$TOML_JSON" | jq -r '.boot_prompt // empty')
        TOML_DELAY=$(echo "$TOML_JSON" | jq -r '.stagger_seconds // empty')
        [ -n "$TOML_BOOT" ]  && BOOT="$TOML_BOOT"
        [ -n "$TOML_DELAY" ] && DELAY="$TOML_DELAY"
        echo "Config loaded from $TOML (stagger=${DELAY}s)"
    else
        echo "Warning: parse_toml.py failed — using defaults"
    fi
else
    echo "Warning: $TOML or $PARSE_TOML not found — using defaults"
fi

# ── Extract agent names + machine types from parsed TOML JSON ────────────────
ALL_AGENTS_STR=$(echo "$TOML_JSON" | jq -r '[.agents[].name] | join(" ")' 2>/dev/null)
read -ra ALL_AGENTS <<< "$ALL_AGENTS_STR"

# Build AGENT_MACHINE associative array from parsed JSON
declare -A AGENT_MACHINE
while IFS=$'\t' read -r agent_name agent_machine; do
    AGENT_MACHINE["$agent_name"]="$agent_machine"
done < <(echo "$TOML_JSON" | jq -r '.agent_machines | to_entries[] | [.key, .value] | @tsv')

# ── Cleanup stale processes ──────────────────────────────────────────────────
cleanup_stale() {
    echo "Cleaning up stale processes..."
    pkill -f "soul-sidecar.sh" 2>/dev/null || true
    pkill -f "soul-sidecar-wrapper.sh" 2>/dev/null || true
    systemctl --user stop soul-courier.service 2>/dev/null || true
    pkill -f "soul-bridge.py" 2>/dev/null || true
    tmux kill-session -t soul-team 2>/dev/null || true
    rm -f ~/.clawteam/teams/soul-team/sidecar/*-seen.log
    rm -f ~/.clawteam/teams/soul-team/sidecar/*-interrupt.lock
    for f in ~/.clawteam/teams/soul-team/queue/*.json; do
        [ -f "$f" ] && echo '[]' > "$f"
    done
    echo "Cleanup done."
}

# ── Continue mode: reattach + heal + revive ─────────────────────────────────
get_agent_launch_cmd() {
    local agent="$1"
    local model
    model=$(echo "$TOML_JSON" | jq -r --arg a "$agent" '.agents[] | select(.name == $a) | .model // "sonnet"' 2>/dev/null)
    [ -z "$model" ] && model="sonnet"
    local dev_flag=""
    [[ " $DEV_AGENTS " == *" $agent "* ]] && dev_flag="--append-system-prompt-file /home/rishav/.claude/CLAUDE-dev.md"
    echo "cd /home/rishav && env CLAUDECODE=1 CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS=1 $C --agent-id ${agent}@${SESSION} --agent-name ${agent} --team-name ${SESSION} --agent-color pink --agent-type ${agent} --model ${model} ${dev_flag}"
}

if [[ "${1:-}" == "--continue" ]]; then
    # Phase 1: Validate session exists
    if ! tmux has-session -t "$SESSION" 2>/dev/null; then
        echo "No soul-team session found. Run 'soul-team' to start fresh."
        exit 1
    fi
    echo "Continuing soul-team session..."

    # Phase 2: Heal — restart courier with fresh pane validation
    systemctl --user restart soul-courier.service 2>/dev/null || true
    pgrep -f "soul-router.py" >/dev/null || {
        python3 "$HOME/.claude/scripts/soul-router.py" >> "$HOME/.claude/logs/soul-router.log" 2>&1 &
        echo "  Router restarted (PID: $!)"
    }

    # Phase 3: Revive dead agents
    if [ -f "$PANES_JSON" ]; then
        for agent in $(jq -r 'keys[]' "$PANES_JSON"); do
            pane_id=$(jq -r ".\"$agent\"" "$PANES_JSON")
            content=$(tmux capture-pane -p -t "$pane_id" -S -5 2>/dev/null) || content=""

            if [ -z "$content" ] || echo "$content" | grep -qE '^\$\s*$|^[a-z]+@[a-zA-Z0-9-]+[^>]*\$\s*$'; then
                echo "  Reviving $agent in pane $pane_id..."
                launch_cmd=$(get_agent_launch_cmd "$agent")
                tmux send-keys -t "$pane_id" "$launch_cmd" Enter
            else
                echo "  $agent: alive"
            fi
        done
    fi

    # Phase 4: Attach
    echo "Attaching to soul-team..."
    tmux attach-session -t "$SESSION"
    exit 0
fi

# ── Parse CLI flags ──────────────────────────────────────────────────────────
SELECTED_AGENTS=()
USE_ALL=false
DRY_RUN=false

while [[ $# -gt 0 ]]; do
    case "$1" in
        --agents)
            if [[ -z "${2:-}" || "$2" == --* ]]; then
                echo "Error: --agents requires a comma-separated list of agent names" >&2
                exit 1
            fi
            IFS=',' read -ra SELECTED_AGENTS <<< "$2"
            shift 2
            ;;
        --all)
            USE_ALL=true
            shift
            ;;
        --dry-run)
            DRY_RUN=true
            shift
            ;;
        *)
            echo "Unknown flag: $1" >&2
            exit 1
            ;;
    esac
done

# --all always wins, regardless of argument order
if $USE_ALL; then
    SELECTED_AGENTS=()
fi

# Empty = all agents (backward-compatible default)
if [[ ${#SELECTED_AGENTS[@]} -eq 0 ]]; then
    SELECTED_AGENTS=("${ALL_AGENTS[@]}")
fi

# Deduplicate (preserving first-seen order)
declare -A _seen
DEDUPED=()
for agent in "${SELECTED_AGENTS[@]}"; do
    if [[ -z "${_seen[$agent]:-}" ]]; then
        _seen[$agent]=1
        DEDUPED+=("$agent")
    fi
done
SELECTED_AGENTS=("${DEDUPED[@]}")

# Validate
for agent in "${SELECTED_AGENTS[@]}"; do
    if [[ -z "${AGENT_MACHINE[$agent]:-}" ]]; then
        echo "Error: unknown agent '$agent'. Valid agents: ${ALL_AGENTS[*]}" >&2
        exit 1
    fi
done
if [[ ${#SELECTED_AGENTS[@]} -eq 0 ]]; then
    echo "Error: no agents specified" >&2
    exit 1
fi

echo "Selected agents (${#SELECTED_AGENTS[@]}): ${SELECTED_AGENTS[*]}"

# ── Dry-run mode: validate config, print roster, check files, exit ───────────
if $DRY_RUN; then
    echo ""
    echo "=== DRY RUN: Config Validation ==="
    echo ""

    # Print agent roster with models and machines
    echo "Agent Roster:"
    printf "  %-14s %-10s %-12s\n" "NAME" "MODEL" "MACHINE"
    printf "  %-14s %-10s %-12s\n" "-----------" "--------" "----------"
    for agent in "${SELECTED_AGENTS[@]}"; do
        agent_model=$(python3 -c "
import re, sys
txt = open(sys.argv[1]).read()
agent = sys.argv[2]
blocks = re.split(r'\[\[agents\]\]', txt)[1:]
for b in blocks:
    nm = re.search(r'name\s*=\s*\"(\w+)\"', b)
    if nm and nm.group(1) == agent:
        m = re.search(r'model\s*=\s*\"(\w+)\"', b)
        print(m.group(1) if m else 'sonnet')
        break
else:
    print('sonnet')
" "$TOML" "$agent" 2>/dev/null)
        printf "  %-14s %-10s %-12s\n" "$agent" "$agent_model" "${AGENT_MACHINE[$agent]}"
    done
    echo ""

    # Verify required files exist
    errors=0
    echo "File Checks:"
    check_file() {
        local label="$1" path="$2"
        if [ -f "$path" ]; then
            echo "  [OK]   $label: $path"
        else
            echo "  [FAIL] $label: $path (NOT FOUND)"
            errors=$((errors + 1))
        fi
    }

    check_file "TOML config" "$TOML"
    check_file "CLAUDE.md (global)" "$HOME/.claude/CLAUDE.md"
    check_file "CLAUDE-dev.md" "$HOME/.claude/CLAUDE-dev.md"
    check_file "clawteam CLI" "$CLAWTEAM"

    # Check agent role files
    for agent in "${SELECTED_AGENTS[@]}"; do
        role_file="$HOME/.claude/agents/${agent}.md"
        if [ -f "$role_file" ]; then
            echo "  [OK]   Agent role: $role_file"
        else
            echo "  [WARN] Agent role: $role_file (not found — may use inline)"
        fi
    done
    echo ""

    # Check service unit files
    echo "Service Units:"
    for svc in soul-guardian soul-courier soul-router; do
        unit_file="$HOME/.config/systemd/user/${svc}.service"
        if [ -f "$unit_file" ]; then
            echo "  [OK]   $svc.service"
        else
            echo "  [WARN] $svc.service (unit file not found at $unit_file)"
        fi
    done
    echo ""

    # Summary
    remote_count=0
    local_count=0
    for agent in "${SELECTED_AGENTS[@]}"; do
        if [[ "${AGENT_MACHINE[$agent]}" == "local" ]]; then
            local_count=$((local_count + 1))
        else
            remote_count=$((remote_count + 1))
        fi
    done
    echo "Summary:"
    echo "  Total agents: ${#SELECTED_AGENTS[@]} (local: $local_count, remote: $remote_count)"
    echo "  Stagger delay: ${DELAY}s"
    echo "  Boot prompt: ${BOOT:0:60}..."
    if [ "$errors" -gt 0 ]; then
        echo ""
        echo "  ERRORS: $errors required file(s) missing. Fix before launching."
        exit 1
    else
        echo ""
        echo "  All checks passed. Safe to launch."
        exit 0
    fi
fi

# ── Dynamic layout function ──────────────────────────────────────────────────
# PANE_MAP and CEO are declared at top level so they're accessible after the function returns.
declare -A PANE_MAP
CEO=""

create_dynamic_layout() {
    local num=${#SELECTED_AGENTS[@]}
    local cols

    if   (( num <= 3 )); then cols=1
    elif (( num <= 6 )); then cols=2
    else                       cols=3
    fi

    # Clean up any stale processes/sessions from previous launches
    cleanup_stale

    # Create session — initial pane becomes CEO
    tmux new-session -d -s "$SESSION" -n "soul"
    CEO=$(tmux display-message -t "$SESSION" -p '#{pane_id}')

    # Horizontal splits: CEO keeps 25%, agents get 75%
    # shellcheck disable=SC2034  # H_SPLITS_* are accessed via indirect expansion below
    local -a H_SPLITS_1=(75)
    # shellcheck disable=SC2034
    local -a H_SPLITS_2=(75 50)
    # shellcheck disable=SC2034
    local -a H_SPLITS_3=(75 66 50)

    local -a col_panes=()
    local splits_ref="H_SPLITS_${cols}[@]"
    local -a splits=("${!splits_ref}")

    local last_pane="$CEO"
    for (( c=0; c<cols; c++ )); do
        tmux split-window -h -t "$last_pane" -l "${splits[c]}%"
        col_panes[c]=$(tmux display-message -t "$SESSION" -p '#{pane_id}')
        last_pane="${col_panes[c]}"
    done

    # Round-robin assign agents to columns
    local -a col_agents=()
    for (( c=0; c<cols; c++ )); do col_agents[c]=""; done
    for (( i=0; i<num; i++ )); do
        local c_idx=$(( i % cols ))
        col_agents[c_idx]+="${SELECTED_AGENTS[i]} "
    done

    # Vertical splits within each column
    for (( c=0; c<cols; c++ )); do
        local -a agents_in_col=()
        read -ra agents_in_col <<< "${col_agents[$c]}"
        local n_rows=${#agents_in_col[@]}
        local -a row_panes=("${col_panes[$c]}")

        if (( n_rows == 2 )); then
            tmux split-window -v -t "${col_panes[$c]}" -l '50%'
            row_panes+=("$(tmux display-message -t "$SESSION" -p '#{pane_id}')")
        elif (( n_rows == 3 )); then
            local mid
            mid=$(tmux split-window -v -t "${col_panes[$c]}" -l '66%' -P -F '#{pane_id}')
            tmux split-window -v -t "$mid" -l '50%'
            local bot
            bot=$(tmux display-message -t "$SESSION" -p '#{pane_id}')
            row_panes+=("$mid" "$bot")
        fi

        for (( r=0; r<n_rows; r++ )); do
            PANE_MAP["${agents_in_col[$r]}"]="${row_panes[$r]}"
            local title="${agents_in_col[$r]^}"
            if [[ "${AGENT_MACHINE[${agents_in_col[$r]}]}" != "local" ]]; then
                title+="*"
            fi
            tmux select-pane -t "${row_panes[$r]}" -T "$title"
        done
    done

    tmux select-pane -t "$CEO" -T "CEO"
}

# ── ClawTeam: init team if not present ─────────────────────────────────────
echo "Initializing ClawTeam team..."
"$CLAWTEAM" team spawn-team soul-team 2>/dev/null || true

# ── Native Teams inbox dir + per-agent inbox files ─────────────────────────
NATIVE_INBOX_DIR="$HOME/.claude/teams/soul-team/inboxes"
mkdir -p "$NATIVE_INBOX_DIR"
for agent in happy xavier hawkeye pepper fury loki shuri stark banner team-lead; do
    inbox_file="$NATIVE_INBOX_DIR/${agent}.json"
    [ -f "$inbox_file" ] || echo '[]' > "$inbox_file"
done
echo "Native inbox files initialized."

# ── ClawTeam inboxes dir + live comms directories ───────────────────────────
mkdir -p "$HOME/.clawteam/teams/soul-team/inboxes"
mkdir -p "$HOME/.clawteam/heartbeat"

# ── Create live comms directories (queue, broadcast, discussions, sidecar) ───
echo "Creating live comms directories..."
mkdir -p "$HOME/.clawteam/teams/soul-team/"{queue,broadcast,discussions,sidecar}
for agent in team-lead happy xavier hawkeye pepper fury loki shuri stark banner; do
    mkdir -p "$HOME/.clawteam/teams/soul-team/inboxes/${agent}_${agent}/archive"
done
echo "Live comms directories ready."

# ── Conditional pre-flight (only SSH if remote agents selected) ──────────────
NEEDS_REMOTE=false
for agent in "${SELECTED_AGENTS[@]}"; do
    if [[ "${AGENT_MACHINE[$agent]}" != "local" ]]; then
        NEEDS_REMOTE=true
        break
    fi
done

if $NEEDS_REMOTE; then
    echo "Checking titan-pc mounts..."
    ssh "$PC" "sudo systemctl start soul-mounts.service 2>/dev/null" || true
else
    echo "All agents are local — skipping titan-pc pre-flight."
fi
tmux has-session -t "$SESSION" 2>/dev/null && tmux kill-session -t "$SESSION"

# ── Create dynamic layout ────────────────────────────────────────────────────
echo "Creating layout (${#SELECTED_AGENTS[@]} agents)..."
create_dynamic_layout

# ── UI config ────────────────────────────────────────────────────────────────
tmux set-option -t "$SESSION" pane-border-status top
tmux set-option -t "$SESSION" pane-border-format " #{pane_title} "
tmux set-option -t "$SESSION" pane-active-border-style "fg=#e8a849"
tmux set-option -t "$SESSION" pane-border-style "fg=#444444"
tmux set-option -t "$SESSION" mouse on
tmux set-option -t "$SESSION" status off
tmux set-option -t "$SESSION" status-interval 10
tmux set-option -t "$SESSION" status-style "bg=#1a1a2e,fg=#e8a849"
tmux set-option -t "$SESSION" status-left-length 100
tmux set-option -t "$SESSION" status-right-length 60
tmux set-option -t "$SESSION" status-left " SOUL TEAM "
tmux set-option -t "$SESSION" status-right " %H:%M "

# ── Write scoped panes.json (only selected agents + team-lead) ───────────────
{
    echo "{"
    echo "  \"team-lead\": \"${CEO}\""
    for agent in "${SELECTED_AGENTS[@]}"; do
        echo ", \"${agent}\": \"${PANE_MAP[$agent]}\""
    done
    echo "}"
} | python3 -c "
import json, sys, os
panes = json.load(sys.stdin)
out_path = os.path.expanduser('${PANES_JSON}')
os.makedirs(os.path.dirname(out_path), exist_ok=True)
with open(out_path, 'w') as f:
    json.dump(panes, f, indent=2)
print(f'panes.json written: {out_path} ({len(panes)} entries)')
"

# ── Launch CEO immediately ───────────────────────────────────────────────────
sleep 1
tmux send-keys -t "$CEO" "export SOUL_AGENT_NAME=team-lead SOUL_TEAM_NAME=soul-team && $C" Enter
tmux select-pane -t "$CEO"

echo ""
echo "  CEO ready. ${#SELECTED_AGENTS[@]} agents launching with ${DELAY}s stagger..."
echo "  Selected: ${SELECTED_AGENTS[*]}"
echo ""

# ── Time context for agent boot prompts ─────────────────────────────────────
get_soul_time() {
    local IST_TIME DATE DAY TIME HOUR WEEK DOW MODE

    IST_TIME=$(TZ=Asia/Kolkata date +"%Y-%m-%dT%H:%M:%S+05:30")
    DATE=$(TZ=Asia/Kolkata date +"%Y-%m-%d")
    DAY=$(TZ=Asia/Kolkata date +"%A")
    TIME=$(TZ=Asia/Kolkata date +"%H:%M")
    HOUR=$(TZ=Asia/Kolkata date +"%H" | sed "s/^0//")
    WEEK=$(TZ=Asia/Kolkata date +"%V")
    DOW=$(TZ=Asia/Kolkata date +"%u")  # 1=Mon, 7=Sun

    MODE="NIGHT"
    if   [ "$HOUR" -ge 6  ] && [ "$HOUR" -lt 11 ]; then MODE="MORNING"
    elif [ "$HOUR" -ge 11 ] && [ "$HOUR" -lt 17 ]; then MODE="AFTERNOON"
    elif [ "$HOUR" -ge 17 ] && [ "$HOUR" -lt 22 ]; then MODE="EVENING"
    fi

    cat <<SOUL_TIME_EOF
[SOUL-TIME]
datetime: ${IST_TIME}
date: ${DATE}
day: ${DAY}
time: ${TIME} IST
mode: ${MODE}
week_number: ${WEEK}
day_of_week: ${DOW}
[/SOUL-TIME]
SOUL_TIME_EOF
}

# ── Agent launch functions ────────────────────────────────────────────────────
launch_local_agent() {
    local PANE=$1
    local AGENT=$2
    local DEV_FLAG=""
    [[ " $DEV_AGENTS " == *" $AGENT "* ]] && DEV_FLAG="--append-system-prompt-file $HOME/.claude/CLAUDE-dev.md"
    # Export team env vars, then start Claude inside CPU-limited cgroup slice
    tmux send-keys -t "$PANE" \
        "export SOUL_AGENT_NAME=${AGENT} SOUL_TEAM_NAME=soul-team && systemd-run --user --slice=soul-agents.slice --scope $C --agent $AGENT $DEV_FLAG" \
        Enter
    # Wait for trust prompt or TUI to load
    sleep 8
    # Accept trust prompt if present (Enter), harmless if TUI already loaded
    tmux send-keys -t "$PANE" Enter
    # Wait for TUI to fully load
    sleep 5
    # Type boot prompt — prepend time context (single-line), then routine instruction
    local TIME_CTX
    TIME_CTX=$(get_soul_time | tr '\n' ' ')
    local AGENT_BOOT="${TIME_CTX} ${BOOT} (You are ${AGENT}. Your preflight data is at ~/.soul/preflight/${AGENT}.txt -- read it instead of running individual checks. Then run: clawteam inbox receive soul-team --agent ${AGENT})"
    tmux send-keys -t "$PANE" "$AGENT_BOOT" Enter
}

launch_remote_agent() {
    local PANE=$1
    local AGENT=$2
    local DEV_FLAG=""
    [[ " $DEV_AGENTS " == *" $AGENT "* ]] && DEV_FLAG="--append-system-prompt-file \$HOME/.claude/CLAUDE-dev.md"
    # SSH into titan-pc with env vars exported, launch Claude agent
    tmux send-keys -t "$PANE" \
        "ssh -t $PC 'export SOUL_AGENT_NAME=${AGENT} SOUL_TEAM_NAME=soul-team && $C --agent $AGENT $DEV_FLAG'" \
        Enter
    # Wait for SSH + trust prompt
    sleep 10
    # Accept trust prompt
    tmux send-keys -t "$PANE" Enter
    # Wait for TUI
    sleep 5
    # Type boot prompt — prepend time context (single-line), then routine instruction
    local TIME_CTX
    TIME_CTX=$(get_soul_time | tr '\n' ' ')
    local AGENT_BOOT="${TIME_CTX} ${BOOT} (You are ${AGENT}. Your preflight data is at ~/.soul/preflight/${AGENT}.txt -- read it instead of running individual checks. Then run: clawteam inbox receive soul-team --agent ${AGENT})"
    tmux send-keys -t "$PANE" "$AGENT_BOOT" Enter
}

# ── Background: launch selected agents with stagger ──────────────────────────
(
    # ── Run preflight for all agents before launch ───────────────────────────
    echo "  Running agent preflight..."
    bash "$HOME/.claude/scripts/agent-preflight.sh" --all 2>/dev/null || true

    # ── Launch selected agents with stagger ──────────────────────────────────
    sleep 3
    for agent in "${SELECTED_AGENTS[@]}"; do
        agent_pane="${PANE_MAP[$agent]}"
        if [[ "${AGENT_MACHINE[$agent]}" == "local" ]]; then
            launch_local_agent "$agent_pane" "$agent"
        else
            launch_remote_agent "$agent_pane" "$agent"
        fi
        sleep "$DELAY"
    done

    echo ""
    echo "  ${#SELECTED_AGENTS[@]} agents launched."

    # ── Start soul-router (message router + discussion manager) ───────────
    echo "  Starting soul-router.service..."
    mkdir -p "$HOME/.claude/logs"
    systemctl --user daemon-reload 2>/dev/null || true
    systemctl --user start soul-router.service 2>/dev/null && \
        echo "  Router: started." || \
        echo "  Router: could not start via systemd — launching directly..."
    # Fallback: launch directly if systemd fails
    if ! systemctl --user is-active soul-router.service >/dev/null 2>&1; then
        python3 "$HOME/.claude/scripts/soul-router.py" >> "$HOME/.claude/logs/soul-router.log" 2>&1 &
        echo "  Router PID: $!"
    fi

    # ── Start courier daemon (replaces sidecars + bridge) ─────────────────
    echo "  Starting soul-courier daemon..."
    systemctl --user daemon-reload 2>/dev/null || true
    systemctl --user start soul-courier.service 2>/dev/null && \
        echo "  Courier: started via systemd." || \
        echo "  Courier: systemd failed — launching directly..."
    if ! systemctl --user is-active soul-courier.service >/dev/null 2>&1; then
        PYTHONPATH="$HOME/.claude/scripts" python3 "$HOME/.claude/scripts/soul-courier.py" \
            >> "$HOME/.claude/logs/soul-courier.log" 2>&1 &
        echo "  Courier PID: $!"
    fi

    # ── Start heartbeat ────────────────────────────────────────────────────
    echo "  Starting soul-heartbeat daemon..."
    bash "$HOME/.claude/scripts/soul-heartbeat.sh" >> "$HOME/.claude/logs/soul-heartbeat.log" 2>&1 &
    HBEAT_PID=$!
    echo "  Heartbeat PID: $HBEAT_PID"

    # ── Start time beacon (mode transition broadcaster) ─────────────────
    echo "  Starting soul-time-beacon..."
    bash "$HOME/.claude/scripts/soul-time-beacon.sh" >> "$HOME/.claude/logs/soul-time-beacon.log" 2>&1 &
    BEACON_PID=$!
    echo "  Time beacon PID: $BEACON_PID"

    # ── Ensure guardian is running ─────────────────────────────────────────
    echo "  Ensuring soul-guardian.service is running..."
    systemctl --user start soul-guardian.service 2>/dev/null && \
        echo "  Guardian: started/confirmed." || \
        echo "  Guardian: could not start (may not be installed)."

    echo "  soul-team v2 fully initialized."
) &

# ── Create log dir if needed ────────────────────────────────────────────────
mkdir -p "$HOME/.claude/logs"

tmux attach-session -t "$SESSION"
