# ============================================
# soul-team .gitignore
# Comprehensive private data exclusion
# ============================================

# ── Python ──────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
*.egg-info/
dist/
build/
.eggs/
*.egg
.venv/
venv/
env/

# ── Node / npm ──────────────────────────────────────────────
node_modules/
npm-debug.log*
yarn-error.log*
package-lock.json

# ── Test artifacts ──────────────────────────────────────────
.pytest_cache/
.coverage
htmlcov/
*.prof

# ── Config (contains sensitive data) ────────────────────────
cluster.yaml
config/soul-team.toml
*.local.yaml
.env
.env.*
!.env.example
!config/*.example

# ── Secrets / Credentials ──────────────────────────────────
*.key
*.pem
*.p12
*.pfx
id_rsa
id_ed25519
credentials.json
*.secret
*.token

# ── Databases ───────────────────────────────────────────────
*.db
*.db-wal
*.db-shm
guardian.db
*.sqlite
*.sqlite3

# ── Logs ────────────────────────────────────────────────────
*.log
*.jsonl
logs/
delivery-log-*.jsonl

# ── Backup files ────────────────────────────────────────────
*.bak
*.bak.*
*.old
archive/

# ── Runtime state ───────────────────────────────────────────
*.pid
*.sock
panes.json
.panes.json

# ── Agent memory / conversation data ────────────────────────
agent-memory/
conversations/
chat-history/
session-data/
sessions/

# ── Inbox / queue / courier ─────────────────────────────────
inboxes/
inbox/
queue/
courier-archive/
events/
broadcast/
discussions/
sidecar/

# ── Guardian / health / heartbeat ───────────────────────────
guardian_state.json
agent_snapshots/
health/
preflight/
heartbeat/
heartbeat*.json
*.heartbeat

# ── ClawTeam runtime ────────────────────────────────────────
.clawteam/

# ── Briefs / reports (working docs, not repo) ──────────────
briefs/
tools-shared/

# ── IDE / Editor ────────────────────────────────────────────
.idea/
.vscode/
*.swp
*.swo
*~

# ── OS files ────────────────────────────────────────────────
.DS_Store
Thumbs.db
.Spotlight-V100
.Trashes

# ── Distribution ────────────────────────────────────────────
*.tar.gz
*.zip

# ── Tmux state ──────────────────────────────────────────────
*.panes.json

# ── soul-team.toml (has real IPs/SSH targets) ──────────────
soul-team.toml
!soul-team.toml.example

# ============================================
# OPERATIONAL DATA — NEVER PUBLISH
# Reviewed by Pepper (CPO) + Fury (Strategy)
# ============================================

# PII — Resumes and cover letters
*.pdf
*resume*
*coverletter*
*cover-letter*

# Compensation and salary data
*comp-research*
*comp-floor*
*salary*
*rate-anchoring*
*contract-product-packaging*

# Outreach emails and lead pipeline
*outreach*
*t3-triage*
*t3-audit*
*t2-audit*
*approved-leads*
*closed-lead*
*pipeline-queue*
*warm-target*

# Trading strategies (alpha is the moat)
stark-trades.md
stark-strategy-document.md
stark-sentiment-daily.md
*war-regime*
*vix-mean-reversion*

# Internal strategic decisions
shared/decisions/
shared/standups/
shared/inbox/
shared/.conference-state/

# Internal strategy docs
*career-trajectory*
*reveal-strategy*
*contract-pivot*
*joint-brief*
*delegated-decisions*
*pre-outreach-readiness*
*90day-master-plan*

# Product internals
pepper-product-registry.md
pepper-roadmap.md
*workload-assessment*
*action-queue*

# Interview prep (company-specific)
*askeffi-prep*
*company-prep*
*toptal-sprint*
*turing-delta*

# Week-ahead / daily ops
*week-ahead*
*ceo-action*

# ── Always track these ──────────────────────────────────────
!examples/
!examples/**
!install.sh
!setup.sh
!README.md
!LICENSE
!GUIDE.md
!SOUL-TEAM.md
